{
  "name": "frontend",
  "type": "directory",
  "modules": {
    "ModuleName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "type": "module",
      "base_interface": "UIElement",
      "exports": ["exportedComponent"],
      "imports": {
        "internal": [
          {
            "path": "frontend/other_module",
            "exports": ["OtherExportedMember"]
          }
        ],
        "external": [
          {
            "package": "ExternalPackageName",
            "exports": ["ExternalExportedMember"]
          }
        ],
        "backend": [
          {
            "path": "backend/endpoints",
            "exports": ["EndpointName"]
          },
          {
            "path": "backend/data_structures",
            "exports": ["StructureName"]
          },
          {
            "path": "backend/error_definitions",
            "exports": ["ErrorType"]
          }
        ],
        "shared": [
          {
            "path": "shared/data_types",
            "exports": ["DataType", "ReturnType"]
          },
          {
            "path": "shared/error_definitions",
            "exports": ["ErrorType"]
          },
          {
            "path": "shared/constants",
            "exports": ["ConstantName"]
          }
        ]
      },
      "dependencies": ["dependencyName"],
      "description": "Description of the UI module",
      "path": "frontend/modules/ModuleName",
      "components": ["ComponentName"],
      "navigation": {
        "NavigationItemName": {
          "function_id": "FunctionID",
          "acceptance_criteria_id": "AcceptanceCriteriaID",
          "path": "/navigation/path",
          "component": "ComponentName",
          "access_controls": ["AccessControlName"],
          "data_loaders": ["DataLoaderName"]
        }
      },
      "state_variables": {
        "variableName": "shared/data_types/DataType"
      },
      "events": {
        "EventName": {
          "function_id": "FunctionID",
          "acceptance_criteria_id": "AcceptanceCriteriaID",
          "trigger": "TriggerCondition",
          "handlers": ["HandlerFunction"]
        }
      }
    }
  },
  "components": {
    "ComponentName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "properties": {
        "propertyName": "shared/data_types/DataType"
      },
      "state_variables": {
        "stateVariableName": "shared/data_types/DataType"
      },
      "functions": {
        "functionName": {
          "function_id": "FunctionID",
          "acceptance_criteria_id": "AcceptanceCriteriaID",
          "parameters": {
            "parameterName": "shared/data_types/DataType"
          },
          "returns": "shared/data_types/ReturnType",
          "description": "Description of the function"
        }
      },
      "event_handlers": {
        "EventName": {
          "function_id": "FunctionID",
          "acceptance_criteria_id": "AcceptanceCriteriaID",
          "handlerFunction": "HandlerFunction",
          "description": "Description of the event handler"
        }
      },
      "templates": {
        "templateName": {
          "path": "frontend/templates/templateName",
          "description": "Description of the template"
        }
      }
    }
  },
  "access_controls": {
    "AccessControlName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "condition": "ConditionFunction",
      "redirect": "/alternate/path",
      "description": "Description of the access control"
    }
  },
  "data_loaders": {
    "DataLoaderName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "dependencies": ["ModuleName"],
      "load_function": {
        "function_body": "LoaderFunctionBody",
        "parameters": {
          "parameterName": "shared/data_types/DataType"
        },
        "returns": "Promise<shared/data_types/ReturnType>",
        "description": "Function that loads data from backend"
      },
      "api_reference": "backend/endpoints/EndpointName",
      "description": "Description of the data loader"
    }
  },
  "utility_modules": {
    "UtilityModuleName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "functions": {
        "utilityFunction": {
          "function_id": "FunctionID",
          "acceptance_criteria_id": "AcceptanceCriteriaID",
          "parameters": {
            "parameterName": "shared/data_types/DataType"
          },
          "returns": "shared/data_types/ReturnType",
          "description": "Description of the utility function"
        }
      },
      "dependencies": ["dependencyName"],
      "description": "Description of the utility module"
    }
  },
  "api_contracts": {
    "EndpointName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "reference": "backend/endpoints/EndpointName",
      "method": "backend/endpoints/EndpointName.method",
      "parameters": "backend/endpoints/EndpointName.parameters",
      "responses": "backend/endpoints/EndpointName.responses",
      "description": "Reference to backend API endpoint"
    }
  },
  "verifiers": {
    "VerifierName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "rules": {
        "ruleName": {
          "condition": "ValidationCondition",
          "message": "Validation message",
          "applies_to": ["ComponentName", "UtilityModuleName"]
        }
      },
      "description": "Description of the verifier"
    }
  },
  "logging": {
    "format": "shared/logging/LogFormat",
    "levels": ["info", "warning", "error"],
    "outputs": ["console", "remote"],
    "filters": ["FilterFunction"],
    "description": "Logging configurations for the interface layer"
  },
  "settings": {
    "settingName": {
      "value": "SettingValue",
      "description": "Description of the setting",
      "default": "DefaultValue",
      "environment_key": "ENV_VARIABLE_KEY",
      "scope": "local"
    }
  },
  "metadata": {
    "modules": ["ModuleName"],
    "components": ["ComponentName"],
    "navigation_items": ["NavigationItemName"],
    "utility_modules": ["UtilityModuleName"],
    "categories": ["UI", "Navigation", "StateManagement"],
    "data_definitions": {
      "DataTypeName": {
        "reference": "backend/data_structures/StructureName",
        "description": "Reference to backend data structure"
      }
    }
  }
}
