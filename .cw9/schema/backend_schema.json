{
  "name": "backend",
  "type": "directory",
  "processors": {
    "ProcessorName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "type": "module",
      "base_interface": "CoreProcessor",
      "exports": ["exportedFunction"],
      "imports": {
        "internal": [
          {
            "path": "backend/other_module",
            "exports": ["OtherExportedMember"]
          }
        ],
        "external": [
          {
            "package": "ExternalPackageName",
            "exports": ["ExternalExportedMember"]
          }
        ],
        "shared": [
          {
            "path": "shared/data_types",
            "exports": ["DataType", "InputType", "ReturnType"]
          },
          {
            "path": "shared/error_definitions",
            "exports": ["ErrorType"]
          },
          {
            "path": "shared/verifiers",
            "exports": ["VerifierName"]
          },
          {
            "path": "shared/constants",
            "exports": ["ConstantName"]
          }
        ]
      },
      "dependencies": ["dependencyName"],
      "description": "Description of the processor module",
      "path": "backend/processors/ProcessorName",
      "operations": {
        "operationName": {
          "function_id": "FunctionID",
          "acceptance_criteria_id": "AcceptanceCriteriaID",
          "parameters": {
            "parameterName": "shared/data_types/DataType"
          },
          "returns": "shared/data_types/ReturnType",
          "error_types": ["shared/error_definitions/ErrorType"],
          "error_handling": "ErrorHandlingStrategy",
          "description": "Description of the operation"
        }
      }
    }
  },
  "endpoints": {
    "EndpointName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "path": "/api/path",
      "method": "HTTPMethod",
      "handler": "RequestHandlerName",
      "filters": ["FilterName"],
      "parameters": {
        "parameterName": "shared/data_types/DataType"
      },
      "responses": {
        "200": {
          "description": "Success response",
          "schema": "shared/data_structures/ResponseSchema"
        },
        "400": {
          "description": "Error response",
          "schema": "shared/error_definitions/ErrorSchema"
        }
      },
      "description": "Description of the endpoint"
    }
  },
  "request_handlers": {
    "RequestHandlerName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "functions": {
        "functionName": {
          "function_id": "FunctionID",
          "acceptance_criteria_id": "AcceptanceCriteriaID",
          "operation": "ProcessorName.operationName",
          "parameters": {
            "parameterName": "shared/data_types/DataType"
          },
          "returns": "shared/data_types/ReturnType",
          "error_handling": "ErrorHandlingStrategy",
          "description": "Description of the function"
        }
      },
      "dependencies": ["ServiceName"],
      "description": "Description of the request handler"
    }
  },
  "data_access_objects": {
    "DataAccessObjectName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "functions": {
        "functionName": {
          "function_id": "FunctionID",
          "acceptance_criteria_id": "AcceptanceCriteriaID",
          "parameters": {
            "parameterName": "shared/data_types/DataType"
          },
          "returns": "shared/data_types/ReturnType",
          "queries": ["DataQuery"],
          "description": "Description of the function"
        }
      },
      "description": "Description of the data access object"
    }
  },
  "services": {
    "ServiceName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "functions": {
        "functionName": {
          "function_id": "FunctionID",
          "acceptance_criteria_id": "AcceptanceCriteriaID",
          "parameters": {
            "parameterName": "shared/data_types/DataType"
          },
          "returns": "shared/data_types/ReturnType",
          "calls": ["DataAccessObjectName.functionName"],
          "description": "Description of the function"
        }
      },
      "dependencies": ["dependencyName"],
      "description": "Description of the service"
    }
  },
  "filters": {
    "FilterName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "function_definition": {
        "parameters": {
          "request": "shared/data_types/RequestType",
          "response": "shared/data_types/ResponseType",
          "next": "Function"
        },
        "returns": "void",
        "description": "Description of the filter function"
      },
      "conditions": ["ExecutionCondition"],
      "description": "Description of the filter"
    }
  },
  "data_structures": {
    "StructureName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "fields": {
        "fieldName": {
          "type": "shared/data_types/DataType",
          "required": true,
          "unique": false,
          "default": "DefaultValue",
          "validation": ["ValidationRule"]
        }
      },
      "relations": {
        "relationName": {
          "type": "RelationType",
          "target": "TargetStructure",
          "description": "Description of the relation"
        }
      },
      "description": "Description of the data structure"
    }
  },
  "verifiers": {
    "VerifierName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "conditions": ["VerificationCondition"],
      "message": "Verification message",
      "applies_to": ["StructureName", "operationName"],
      "description": "Description of the verifier"
    }
  },
  "error_definitions": {
    "ErrorType": {
      "message": "Error message",
      "code": "ErrorCode",
      "description": "Description of the error",
      "category": "ErrorCategory"
    }
  },
  "logging": {
    "format": "shared/logging/LogFormat",
    "levels": ["debug", "info", "warning", "error"],
    "outputs": ["console", "file", "remote"],
    "filters": ["FilterFunction"],
    "description": "Logging configurations for the processing layer"
  },
  "settings": {
    "settingName": {
      "value": "SettingValue",
      "description": "Description of the setting",
      "default": "DefaultValue",
      "environment_key": "ENV_VARIABLE_KEY",
      "scope": "global"
    }
  },
  "process_chains": {
    "ProcessChainName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "steps": ["ProcessorName.operationName"],
      "conditions": ["ExecutionCondition"],
      "description": "Description of the process chain"
    }
  },
  "metadata": {
    "function_id": "FunctionID",
    "processors": ["ProcessorName"],
    "endpoints": ["EndpointName"],
    "request_handlers": ["RequestHandlerName"],
    "services": ["ServiceName"],
    "data_access_objects": ["DataAccessObjectName"],
    "data_structures": ["StructureName"],
    "categories": ["BusinessLogic", "DataAccess", "API"],
    "data_definitions": {
      "DataTypeName": {
        "description": "Description of the data type",
        "fields": {
          "fieldName": "shared/data_types/DataType"
        }
      }
    }
  }
}
