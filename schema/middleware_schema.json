{
  "name": "middleware",
  "type": "directory",
  "interceptors": {
    "InterceptorName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "type": "module",
      "base_interface": "shared/interceptor_interfaces/InterceptorInterfaceName",
      "exports": ["interceptorFunction"],
      "imports": {
        "internal": [
          {
            "path": "path/to/internal/module",
            "exports": ["exportedMember"]
          }
        ],
        "external": [
          {
            "package": "ExternalPackageName",
            "exports": ["exportedMember"]
          }
        ],
        "shared": [
          {
            "path": "shared/interceptor_interfaces",
            "exports": ["InterceptorInterfaceName"]
          },
          {
            "path": "shared/data_types",
            "exports": ["InputType", "ContextType", "ReturnType"]
          },
          {
            "path": "shared/error_definitions",
            "exports": ["ErrorType"]
          }
        ]
      },
      "dependencies": ["dependencyName"],
      "description": "Description of the interceptor",
      "path": "path/to/interceptor",
      "function_definition": {
        "parameters": {
          "input": "shared/data_types/InputType",
          "context": "shared/data_types/ContextType"
        },
        "returns": "shared/data_types/ReturnType",
        "description": "Description of the interceptor function"
      },
      "execution_stage": "ExecutionStage",
      "priority": "ExecutionPriority",
      "conditions": ["ExecutionCondition"],
      "actions": ["ActionName"]
    }
  },
  "execution_patterns": {
    "PatternName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "conditions": ["TriggerCondition"],
      "rules": ["ExecutionRule"],
      "bypass_conditions": ["BypassCondition"],
      "description": "Description of the execution pattern"
    }
  },
  "process_chains": {
    "ChainName": {
      "function_id": "FunctionID",
      "acceptance_criteria_id": "AcceptanceCriteriaID",
      "interceptors": ["InterceptorName"],
      "order": ["PreProcessing", "PostProcessing"],
      "conditions": ["ChainCondition"],
      "description": "Purpose of the interceptor chain"
    }
  },
  "metadata": {
    "interceptors": ["InterceptorName"],
    "execution_patterns": ["PatternName"],
    "categories": ["Authentication", "Logging", "ErrorHandling"],
    "execution_stages": {
      "PreProcessing": {
        "description": "Interceptors executed before main processing",
        "order": 1
      },
      "PostProcessing": {
        "description": "Interceptors executed after main processing",
        "order": 2
      }
    },
    "interception_points": {
      "Request": {
        "description": "Interception point at the request phase",
        "applies_to": ["InterceptorName"]
      },
      "Response": {
        "description": "Interception point at the response phase",
        "applies_to": ["InterceptorName"]
      }
    }
  }
}
