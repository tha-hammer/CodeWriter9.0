    },
    "assert_NoSessionAfterExit": {
      "condition": "worker_exited implies ~session_active",
      "message": "Assertion failed: NoSessionAfterExit \u2014 worker_exited => ~session_active",
      "description": "Test assertion for NoSessionAfterExit from GWT0006_SafeDisconnect spec"
    },
    "assert_TypeInvariant": {
      "condition": "and ClientValid\n    and OutcomeValid\n    and RetryBounded\n    and finally_entered in BOOLEAN\n    and worker_exited   in BOOLEAN\n    and session_active  in BOOLEAN",
      "message": "Assertion failed: TypeInvariant \u2014 /\\ ClientValid\n    /\\ OutcomeValid\n    /\\ RetryBounded\n    /\\ finally_entered \\in BOOLEAN\n    /\\ worker_exited   \\in ...",
      "description": "Test assertion for TypeInvariant from GWT0006_SafeDisconnect spec"
    }
