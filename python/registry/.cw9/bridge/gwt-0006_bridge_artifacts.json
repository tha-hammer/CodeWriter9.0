      "applies_to": [
        "client_state"
      ],
      "description": "Verifier for invariant ClientValid from GWT0006_SafeDisconnect spec"
    },
    "OutcomeValid": {
      "function_id": "fn-GWT0006_SafeDisconnect-verify-OutcomeValid",
      "acceptance_criteria_id": "ac-GWT0006_SafeDisconnect-OutcomeValid",
      "conditions": [
        "loop_outcome \\in LoopOutcomes"
      ],
      "message": "OutcomeValid violation: loop_outcome \\in LoopOutcomes",
      "applies_to": [
        "loop_outcome"
      ],
      "description": "Verifier for invariant OutcomeValid from GWT0006_SafeDisconnect spec"
    },
    "RetryBounded": {
      "function_id": "fn-GWT0006_SafeDisconnect-verify-RetryBounded",
      "acceptance_criteria_id": "ac-GWT0006_SafeDisconnect-RetryBounded",
      "conditions": [
        "retry_count <= MaxRetries"
      ],
      "message": "RetryBounded violation: retry_count <= MaxRetries",
      "applies_to": [
        "retry_count"
      ],
      "description": "Verifier for invariant RetryBounded from GWT0006_SafeDisconnect spec"
    },
    "SafeDisconnectGuarantee": {
      "function_id": "fn-GWT0006_SafeDisconnect-verify-SafeDisconnectGuarantee",
      "acceptance_criteria_id": "ac-GWT0006_SafeDisconnect-SafeDisconnectGuarantee",
      "conditions": [
        "worker_exited => (client_state = \"disconnected\"",
        "~session_active"
      ],
      "message": "SafeDisconnectGuarantee violation: worker_exited => (client_state = \"disconnected\" /\\ ~session_active)",
      "applies_to": [
        "client_state",
        "session_active",
        "worker_exited"
      ],
      "description": "Verifier for invariant SafeDisconnectGuarantee from GWT0006_SafeDisconnect spec"
    },
    "FinallyAlwaysEntered": {
      "function_id": "fn-GWT0006_SafeDisconnect-verify-FinallyAlwaysEntered",
      "acceptance_criteria_id": "ac-GWT0006_SafeDisconnect-FinallyAlwaysEntered",
      "conditions": [
        "worker_exited => finally_entered"
      ],
      "message": "FinallyAlwaysEntered violation: worker_exited => finally_entered",
      "applies_to": [
        "finally_entered",
        "worker_exited"
      ],
      "description": "Verifier for invariant FinallyAlwaysEntered from GWT0006_SafeDisconnect spec"
    },
    "NoSessionAfterExit": {
      "function_id": "fn-GWT0006_SafeDisconnect-verify-NoSessionAfterExit",
      "acceptance_criteria_id": "ac-GWT0006_SafeDisconnect-NoSessionAfterExit",
      "conditions": [
        "worker_exited => ~session_active"
      ],
      "message": "NoSessionAfterExit violation: worker_exited => ~session_active",
      "applies_to": [
        "session_active",
        "worker_exited"
      ],
      "description": "Verifier for invariant NoSessionAfterExit from GWT0006_SafeDisconnect spec"
    },
    "TypeInvariant": {
      "function_id": "fn-GWT0006_SafeDisconnect-verify-TypeInvariant",
      "acceptance_criteria_id": "ac-GWT0006_SafeDisconnect-TypeInvariant",
      "conditions": [
        "ClientValid",
        "OutcomeValid",
        "RetryBounded",
        "finally_entered \\in BOOLEAN",
        "worker_exited   \\in BOOLEAN",
        "session_active  \\in BOOLEAN"
      ],
      "message": "TypeInvariant violation: /\\ ClientValid\n    /\\ OutcomeValid\n    /\\ RetryBounded\n    /\\ finally_entered \\in BOOLEAN\n    /\\ worker_exited   \\in ...",
      "applies_to": [
        "finally_entered",
        "session_active",
        "worker_exited"
      ],
      "description": "Verifier for invariant TypeInvariant from GWT0006_SafeDisconnect spec"
    }
  },
