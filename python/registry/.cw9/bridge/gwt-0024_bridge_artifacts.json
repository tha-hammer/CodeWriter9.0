    },
    "assert_ValidState": {
      "condition": "current_state in States",
      "message": "Assertion failed: ValidState \u2014 current_state \\in States",
      "description": "Test assertion for ValidState from GWT0024WriteResult spec"
    },
    "assert_BoundedExecution": {
      "condition": "step_count <= MaxSteps",
