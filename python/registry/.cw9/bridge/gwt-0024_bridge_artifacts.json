  "assertions": {
    "assert_TypeInvariant": {
      "condition": "and current_state       in States\n    and job_outcome         in (JobOutcomes \\union {\"NONE\"})\n    and attempts            in Nat\n    and db_written          in BOOLEAN\n    and storage_uploaded    in BOOLEAN\n    and local_written       in BOOLEAN\n    and write_result_called in BOOLEAN",
      "message": "Assertion failed: TypeInvariant \u2014 /\\ current_state       \\in States\n    /\\ job_outcome         \\in (JobOutcomes \\union {\"NONE\"})\n    /\\ attempts       ...",
