      "description": "Test assertion for NoLocalWrite from GWT0024WriteResult spec"
    },
    "assert_PersistenceConsistency": {
      "condition": "current_state = \"Persisted\" implies\n        (db_written = TRUE and storage_uploaded = TRUE)",
      "message": "Assertion failed: PersistenceConsistency \u2014 current_state = \"Persisted\" =>\n        (db_written = TRUE /\\ storage_uploaded = TRUE)",
      "description": "Test assertion for PersistenceConsistency from GWT0024WriteResult spec"
    },
    "assert_DBWriteRequiresOutcome": {
      "condition": "db_written = TRUE implies job_outcome in JobOutcomes",
      "message": "Assertion failed: DBWriteRequiresOutcome \u2014 db_written = TRUE => job_outcome \\in JobOutcomes",
      "description": "Test assertion for DBWriteRequiresOutcome from GWT0024WriteResult spec"
    },
    "assert_StorageRequiresDB": {
      "condition": "storage_uploaded = TRUE implies db_written = TRUE",
      "message": "Assertion failed: StorageRequiresDB \u2014 storage_uploaded = TRUE => db_written = TRUE",
      "description": "Test assertion for StorageRequiresDB from GWT0024WriteResult spec"
    },
    "assert_WriteCalledRequiresOutcome": {
      "condition": "write_result_called = TRUE implies job_outcome in JobOutcomes",
      "message": "Assertion failed: WriteCalledRequiresOutcome \u2014 write_result_called = TRUE => job_outcome \\in JobOutcomes",
      "description": "Test assertion for WriteCalledRequiresOutcome from GWT0024WriteResult spec"
    },
    "assert_HostedReplacement": {
      "condition": "write_result_called = TRUE implies local_written = FALSE",
      "message": "Assertion failed: HostedReplacement \u2014 write_result_called = TRUE => local_written = FALSE",
      "description": "Test assertion for HostedReplacement from GWT0024WriteResult spec"
    },
    "assert_OrderingConsistency": {
      "condition": "storage_uploaded = TRUE implies write_result_called = TRUE",
      "message": "Assertion failed: OrderingConsistency \u2014 storage_uploaded = TRUE => write_result_called = TRUE",
      "description": "Test assertion for OrderingConsistency from GWT0024WriteResult spec"
    }
