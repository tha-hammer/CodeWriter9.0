      ],
      "message": "CredentialsFromInjectedOnly violation: client_initialized => credentials_source = \"injected\"",
      "applies_to": [
        "client_initialized",
        "credentials_source"
      ],
      "description": "Verifier for invariant CredentialsFromInjectedOnly from WorkerClientInit spec"
    },
    "ClientReadyImpliesInjectedEnv": {
