  "verifiers": {
    "TypeInvariant": {
      "function_id": "fn-WorkerClientInit-verify-TypeInvariant",
      "acceptance_criteria_id": "ac-WorkerClientInit-TypeInvariant",
      "conditions": [
        "worker_state            \\in WorkerStates",
        "env_source              \\in CredSources",
        "init_path               \\in InitPaths",
        "credentials_source      \\in CredSources",
        "client_initialized      \\in BOOLEAN",
        "injected_has_claudecode  \\in BOOLEAN",
        "inherited_has_claudecode \\in BOOLEAN"
      ],
      "message": "TypeInvariant violation: /\\ worker_state            \\in WorkerStates\n    /\\ env_source              \\in CredSources\n    /\\ init_path          ...",
      "applies_to": [
        "client_initialized",
        "credentials_source",
        "env_source",
        "inherited_has_claudecode",
        "init_path",
        "injected_has_claudecode",
        "worker_state"
      ],
      "description": "Verifier for invariant TypeInvariant from WorkerClientInit spec"
    },
    "BoundedExecution": {
      "function_id": "fn-WorkerClientInit-verify-BoundedExecution",
      "acceptance_criteria_id": "ac-WorkerClientInit-BoundedExecution",
      "conditions": [
        "step_count <= MaxSteps"
      ],
      "message": "BoundedExecution violation: step_count <= MaxSteps",
      "applies_to": [
        "step_count"
      ],
      "description": "Verifier for invariant BoundedExecution from WorkerClientInit spec"
    },
    "CredentialsFromInjectedOnly": {
      "function_id": "fn-WorkerClientInit-verify-CredentialsFromInjectedOnly",
      "acceptance_criteria_id": "ac-WorkerClientInit-CredentialsFromInjectedOnly",
      "conditions": [
