  "data_structures": {
    "CorrectionAgentOptionsState": {
      "function_id": "fn-CorrectionAgentOptions-state",
      "acceptance_criteria_id": "ac-CorrectionAgentOptions-state",
      "fields": {
        "pc": {
          "type": "shared/data_types/Record",
          "required": true,
          "unique": false,
          "default": "[self \\in ProcSet |-> \"Assemble\"]",
          "validation": [
            "NotNull"
          ]
        },
        "phase": {
          "type": "shared/data_types/String",
          "required": true,
          "unique": false,
          "default": "idle",
          "validation": [
            "IsString"
          ]
        },
        "allowed_tools": {
          "type": "shared/data_types/Set",
          "required": true,
          "unique": false,
          "default": "empty_set",
          "validation": [
            "IsSet"
          ]
        },
        "max_turns": {
          "type": "shared/data_types/Integer",
          "required": true,
          "unique": false,
          "default": "0",
          "validation": [
            "IsInteger"
          ]
        },
        "model": {
          "type": "shared/data_types/String",
          "required": true,
          "unique": false,
          "default": "",
          "validation": [
            "IsString"
          ]
        },
        "system_prompt": {
          "type": "shared/data_types/String",
          "required": true,
          "unique": false,
          "default": "",
          "validation": [
            "IsString"
          ]
        },
        "output_format": {
          "type": "shared/data_types/String",
          "required": true,
          "unique": false,
          "default": "UNSET",
          "validation": [
            "IsString"
          ]
        },
        "options_valid": {
          "type": "shared/data_types/Boolean",
          "required": true,
          "unique": false,
          "default": "false",
          "validation": [
            "IsBoolean"
          ]
        },
        "step_count": {
          "type": "shared/data_types/Integer",
          "required": true,
          "unique": false,
          "default": "0",
          "validation": [
            "IsInteger"
          ]
        }
      },
      "relations": {},
      "description": "State model derived from CorrectionAgentOptions TLA+ spec"
    }
  },
