  "verifiers": {
    "TypeOK": {
      "function_id": "fn-ExtractPreservesGwts-verify-TypeOK",
      "acceptance_criteria_id": "ac-ExtractPreservesGwts-TypeOK",
      "conditions": [
        "phase \\in {\"load_old\", \"extract\", \"merge\", \"save\", \"done\"}",
        "step_count <= MaxSteps"
      ],
      "message": "TypeOK violation: /\\ phase \\in {\"load_old\", \"extract\", \"merge\", \"save\", \"done\"}\n    /\\ step_count <= MaxSteps",
      "applies_to": [
        "phase",
        "step_count"
      ],
      "description": "Verifier for invariant TypeOK from ExtractPreservesGwts spec"
    },
    "GwtPreserved": {
      "function_id": "fn-ExtractPreservesGwts-verify-GwtPreserved",
      "acceptance_criteria_id": "ac-ExtractPreservesGwts-GwtPreserved",
      "conditions": [
        "phase = \"done\" => old_gwt_nodes \\subseteq result_nodes"
      ],
      "message": "GwtPreserved violation: phase = \"done\" => old_gwt_nodes \\subseteq result_nodes",
      "applies_to": [
        "old_gwt_nodes",
        "phase",
        "result_nodes"
      ],
      "description": "Verifier for invariant GwtPreserved from ExtractPreservesGwts spec"
    },
    "SchemaFresh": {
      "function_id": "fn-ExtractPreservesGwts-verify-SchemaFresh",
      "acceptance_criteria_id": "ac-ExtractPreservesGwts-SchemaFresh",
      "conditions": [
        "phase = \"done\" => extracted_nodes \\subseteq result_nodes"
      ],
      "message": "SchemaFresh violation: phase = \"done\" => extracted_nodes \\subseteq result_nodes",
      "applies_to": [
        "extracted_nodes",
        "phase",
        "result_nodes"
      ],
      "description": "Verifier for invariant SchemaFresh from ExtractPreservesGwts spec"
    },
    "NoGwtLoss": {
      "function_id": "fn-ExtractPreservesGwts-verify-NoGwtLoss",
      "acceptance_criteria_id": "ac-ExtractPreservesGwts-NoGwtLoss",
      "conditions": [
        "phase = \"done\" => \\A n \\in old_gwt_nodes : n \\in result_nodes"
      ],
      "message": "NoGwtLoss violation: phase = \"done\" => \\A n \\in old_gwt_nodes : n \\in result_nodes",
      "applies_to": [
        "old_gwt_nodes",
        "phase",
        "result_nodes"
      ],
      "description": "Verifier for invariant NoGwtLoss from ExtractPreservesGwts spec"
    },
    "BoundedExecution": {
      "function_id": "fn-ExtractPreservesGwts-verify-BoundedExecution",
      "acceptance_criteria_id": "ac-ExtractPreservesGwts-BoundedExecution",
      "conditions": [
        "step_count <= MaxSteps"
      ],
      "message": "BoundedExecution violation: step_count <= MaxSteps",
      "applies_to": [
        "step_count"
      ],
      "description": "Verifier for invariant BoundedExecution from ExtractPreservesGwts spec"
    },
    "MergeCorrect": {
      "function_id": "fn-ExtractPreservesGwts-verify-MergeCorrect",
      "acceptance_criteria_id": "ac-ExtractPreservesGwts-MergeCorrect",
      "conditions": [
        "phase = \"done\" => result_nodes = extracted_nodes \\union old_gwt_nodes"
      ],
      "message": "MergeCorrect violation: phase = \"done\" => result_nodes = extracted_nodes \\union old_gwt_nodes",
      "applies_to": [
        "extracted_nodes",
        "old_gwt_nodes",
        "phase",
        "result_nodes"
      ],
      "description": "Verifier for invariant MergeCorrect from ExtractPreservesGwts spec"
    }
  },
