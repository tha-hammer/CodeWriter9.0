      "description": "Test assertion for SchemaFresh from ExtractPreservesGwts spec"
    },
    "assert_NoGwtLoss": {
      "condition": "phase = \"done\" implies \\A n in old_gwt_nodes : n in result_nodes",
      "message": "Assertion failed: NoGwtLoss \u2014 phase = \"done\" => \\A n \\in old_gwt_nodes : n \\in result_nodes",
      "description": "Test assertion for NoGwtLoss from ExtractPreservesGwts spec"
    },
    "assert_BoundedExecution": {
      "condition": "step_count <= MaxSteps",
