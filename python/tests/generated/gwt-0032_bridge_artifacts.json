    "assert_TypeOK": {
      "condition": "and phase in {\"load_old\", \"extract\", \"merge\", \"save\", \"done\"}\n    and step_count <= MaxSteps",
      "message": "Assertion failed: TypeOK \u2014 /\\ phase \\in {\"load_old\", \"extract\", \"merge\", \"save\", \"done\"}\n    /\\ step_count <= MaxSteps",
