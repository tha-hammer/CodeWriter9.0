  "verifiers": {
    "SeedAlwaysIncluded": {
      "function_id": "fn-ForwardSubgraphComplete-verify-SeedAlwaysIncluded",
      "acceptance_criteria_id": "ac-ForwardSubgraphComplete-SeedAlwaysIncluded",
      "conditions": [
        "phase /= \"init\" => StartNode \\in visited"
      ],
      "message": "SeedAlwaysIncluded violation: phase /= \"init\" => StartNode \\in visited",
      "applies_to": [
        "phase",
        "visited"
      ],
      "description": "Verifier for invariant SeedAlwaysIncluded from ForwardSubgraphComplete spec"
    },
    "ChainFullyCovered": {
      "function_id": "fn-ForwardSubgraphComplete-verify-ChainFullyCovered",
      "acceptance_criteria_id": "ac-ForwardSubgraphComplete-ChainFullyCovered",
      "conditions": [
        "phase = \"complete\" =>",
        "NA \\in visited",
        "NB \\in visited",
        "NC \\in visited"
      ],
      "message": "ChainFullyCovered violation: phase = \"complete\" =>\n        /\\ NA \\in visited\n        /\\ NB \\in visited\n        /\\ NC \\in visited",
      "applies_to": [
        "phase",
        "visited"
      ],
      "description": "Verifier for invariant ChainFullyCovered from ForwardSubgraphComplete spec"
    },
    "CompletenessInvariant": {
      "function_id": "fn-ForwardSubgraphComplete-verify-CompletenessInvariant",
      "acceptance_criteria_id": "ac-ForwardSubgraphComplete-CompletenessInvariant",
      "conditions": [
        "phase = \"complete\" => Reachable \\subseteq visited"
      ],
      "message": "CompletenessInvariant violation: phase = \"complete\" => Reachable \\subseteq visited",
      "applies_to": [
        "phase",
        "visited"
      ],
      "description": "Verifier for invariant CompletenessInvariant from ForwardSubgraphComplete spec"
    },
    "FrontierSubsetVisited": {
      "function_id": "fn-ForwardSubgraphComplete-verify-FrontierSubsetVisited",
      "acceptance_criteria_id": "ac-ForwardSubgraphComplete-FrontierSubsetVisited",
      "conditions": [
        "frontier \\subseteq visited"
      ],
      "message": "FrontierSubsetVisited violation: frontier \\subseteq visited",
      "applies_to": [
        "frontier",
        "visited"
      ],
      "description": "Verifier for invariant FrontierSubsetVisited from ForwardSubgraphComplete spec"
    },
    "BoundedDepth": {
      "function_id": "fn-ForwardSubgraphComplete-verify-BoundedDepth",
      "acceptance_criteria_id": "ac-ForwardSubgraphComplete-BoundedDepth",
      "conditions": [
        "depth <= MaxSteps"
      ],
      "message": "BoundedDepth violation: depth <= MaxSteps",
      "applies_to": [
        "depth"
      ],
      "description": "Verifier for invariant BoundedDepth from ForwardSubgraphComplete spec"
    },
    "ValidPhase": {
      "function_id": "fn-ForwardSubgraphComplete-verify-ValidPhase",
      "acceptance_criteria_id": "ac-ForwardSubgraphComplete-ValidPhase",
      "conditions": [
        "phase \\in {\"init\", \"expanding\", \"complete\", \"partial\"}"
      ],
      "message": "ValidPhase violation: phase \\in {\"init\", \"expanding\", \"complete\", \"partial\"}",
      "applies_to": [
        "phase"
      ],
      "description": "Verifier for invariant ValidPhase from ForwardSubgraphComplete spec"
    }
  },
  "assertions": {
    "assert_SeedAlwaysIncluded": {
      "condition": "phase /= \"init\" implies StartNode in visited",
      "message": "Assertion failed: SeedAlwaysIncluded \u2014 phase /= \"init\" => StartNode \\in visited",
      "description": "Test assertion for SeedAlwaysIncluded from ForwardSubgraphComplete spec"
    },
    "assert_ChainFullyCovered": {
      "condition": "phase = \"complete\" implies\n        and NA in visited\n        and NB in visited\n        and NC in visited",
      "message": "Assertion failed: ChainFullyCovered \u2014 phase = \"complete\" =>\n        /\\ NA \\in visited\n        /\\ NB \\in visited\n        /\\ NC \\in visited",
      "description": "Test assertion for ChainFullyCovered from ForwardSubgraphComplete spec"
    },
    "assert_CompletenessInvariant": {
      "condition": "phase = \"complete\" implies Reachable \\subseteq visited",
      "message": "Assertion failed: CompletenessInvariant \u2014 phase = \"complete\" => Reachable \\subseteq visited",
      "description": "Test assertion for CompletenessInvariant from ForwardSubgraphComplete spec"
    },
    "assert_FrontierSubsetVisited": {
      "condition": "frontier \\subseteq visited",
      "message": "Assertion failed: FrontierSubsetVisited \u2014 frontier \\subseteq visited",
      "description": "Test assertion for FrontierSubsetVisited from ForwardSubgraphComplete spec"
    },
    "assert_BoundedDepth": {
      "condition": "depth <= MaxSteps",
      "message": "Assertion failed: BoundedDepth \u2014 depth <= MaxSteps",
      "description": "Test assertion for BoundedDepth from ForwardSubgraphComplete spec"
    },
    "assert_ValidPhase": {
      "condition": "phase in {\"init\", \"expanding\", \"complete\", \"partial\"}",
      "message": "Assertion failed: ValidPhase \u2014 phase \\in {\"init\", \"expanding\", \"complete\", \"partial\"}",
      "description": "Test assertion for ValidPhase from ForwardSubgraphComplete spec"
    }
  },
