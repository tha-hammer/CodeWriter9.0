  "module_name": "ForwardSubgraphComplete",
  "data_structures": {
    "ForwardSubgraphCompleteState": {
      "function_id": "fn-ForwardSubgraphComplete-state",
      "acceptance_criteria_id": "ac-ForwardSubgraphComplete-state",
      "fields": {
        "pc": {
          "type": "shared/data_types/Record",
          "required": true,
          "unique": false,
          "default": "[self \\in ProcSet |-> \"Seed\"]",
          "validation": [
            "NotNull"
          ]
        },
        "visited": {
          "type": "shared/data_types/Set",
          "required": true,
          "unique": false,
          "default": "empty_set",
          "validation": [
            "IsSet"
          ]
        },
        "frontier": {
          "type": "shared/data_types/Set",
          "required": true,
          "unique": false,
          "default": "empty_set",
          "validation": [
            "IsSet"
          ]
        },
        "phase": {
          "type": "shared/data_types/String",
          "required": true,
          "unique": false,
          "default": "init",
          "validation": [
            "IsString"
          ]
        },
        "depth": {
          "type": "shared/data_types/Integer",
          "required": true,
          "unique": false,
          "default": "0",
          "validation": [
            "IsInteger"
          ]
        }
      },
      "relations": {},
      "description": "State model derived from ForwardSubgraphComplete TLA+ spec"
    }
  },
