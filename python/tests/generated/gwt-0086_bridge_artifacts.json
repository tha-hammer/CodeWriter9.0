      "applies_to": [
        "json_mode",
        "stdout_written"
      ],
      "description": "Verifier for invariant NoStreaming from RunReviewPassAutoFix spec"
    },
    "ResultCaptured": {
      "function_id": "fn-RunReviewPassAutoFix-verify-ResultCaptured",
      "acceptance_criteria_id": "ac-RunReviewPassAutoFix-ResultCaptured",
      "conditions": [
        "phase = \"complete\") => result_captured"
      ],
      "message": "ResultCaptured violation: (phase = \"complete\") => result_captured",
      "applies_to": [
        "phase",
        "result_captured"
      ],
      "description": "Verifier for invariant ResultCaptured from RunReviewPassAutoFix spec"
    },
    "CostAccumulated": {
      "function_id": "fn-RunReviewPassAutoFix-verify-CostAccumulated",
      "acceptance_criteria_id": "ac-RunReviewPassAutoFix-CostAccumulated",
      "conditions": [
        "result_captured => cost_captured"
      ],
      "message": "CostAccumulated violation: result_captured => cost_captured",
      "applies_to": [
        "cost_captured",
        "result_captured"
      ],
      "description": "Verifier for invariant CostAccumulated from RunReviewPassAutoFix spec"
    },
    "VerdictParsed": {
      "function_id": "fn-RunReviewPassAutoFix-verify-VerdictParsed",
      "acceptance_criteria_id": "ac-RunReviewPassAutoFix-VerdictParsed",
      "conditions": [
        "phase = \"complete\") => verdict \\in Verdicts"
      ],
      "message": "VerdictParsed violation: (phase = \"complete\") => verdict \\in Verdicts",
      "applies_to": [
        "phase",
        "verdict"
      ],
      "description": "Verifier for invariant VerdictParsed from RunReviewPassAutoFix spec"
    },
    "BoundedExecution": {
      "function_id": "fn-RunReviewPassAutoFix-verify-BoundedExecution",
      "acceptance_criteria_id": "ac-RunReviewPassAutoFix-BoundedExecution",
      "conditions": [
        "step_count <= MaxSteps"
      ],
      "message": "BoundedExecution violation: step_count <= MaxSteps",
      "applies_to": [
        "step_count"
      ],
      "description": "Verifier for invariant BoundedExecution from RunReviewPassAutoFix spec"
    },
    "TypeOK": {
      "function_id": "fn-RunReviewPassAutoFix-verify-TypeOK",
      "acceptance_criteria_id": "ac-RunReviewPassAutoFix-TypeOK",
      "conditions": [
        "json_mode         \\in BOOLEAN",
        "query_constructed \\in BOOLEAN",
        "stdout_written    \\in BOOLEAN",
        "result_captured   \\in BOOLEAN",
        "cost_captured     \\in BOOLEAN",
        "verdict           \\in (Verdicts \\union {\"none\"}",
        "phase             \\in {\"init\", \"init_done\", \"query_constructed\",\n                              \"messages_processed\", \"result_captured\", \"complete\"}",
        "step_count        \\in 0..MaxSteps"
      ],
      "message": "TypeOK violation: /\\ json_mode         \\in BOOLEAN\n    /\\ query_constructed \\in BOOLEAN\n    /\\ stdout_written    \\in BOOLEAN\n    /\\ res...",
      "applies_to": [
        "cost_captured",
        "json_mode",
        "phase",
        "query_constructed",
        "result_captured",
        "stdout_written",
        "step_count",
        "verdict"
      ],
      "description": "Verifier for invariant TypeOK from RunReviewPassAutoFix spec"
    }
  },
