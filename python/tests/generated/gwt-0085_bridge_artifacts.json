      "applies_to": [
        "auto_fix",
        "cli_retries_omitted",
        "error_raised",
        "forwarded",
        "phase"
      ],
      "description": "Verifier for invariant TypeOK from CmdPlanReviewMaxRetries spec"
    },
    "NegativeRejected": {
      "function_id": "fn-CmdPlanReviewMaxRetries-verify-NegativeRejected",
      "acceptance_criteria_id": "ac-CmdPlanReviewMaxRetries-NegativeRejected",
      "conditions": [
        "cli_retries_omitted = FALSE",
        "cli_retries_value < 0",
        "phase \\notin {\"init\", \"parsed\"})\n        => error_raised = TRUE"
      ],
      "message": "NegativeRejected violation: (/\\ cli_retries_omitted = FALSE\n     /\\ cli_retries_value < 0\n     /\\ phase \\notin {\"init\", \"parsed\"})\n        => err...",
      "applies_to": [
        "cli_retries_omitted",
        "cli_retries_value",
        "error_raised",
        "phase"
      ],
      "description": "Verifier for invariant NegativeRejected from CmdPlanReviewMaxRetries spec"
    },
    "MaxRetriesForwarded": {
