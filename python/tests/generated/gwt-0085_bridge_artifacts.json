    "TypeOK": {
      "function_id": "fn-CmdPlanReviewMaxRetries-verify-TypeOK",
      "acceptance_criteria_id": "ac-CmdPlanReviewMaxRetries-TypeOK",
      "conditions": [
        "phase \\in {\"init\", \"parsed\", \"validated\", \"forwarded\", \"complete\", \"rejected\"}",
        "error_raised \\in BOOLEAN",
