  "assertions": {
    "assert_TypeOK": {
      "condition": "and phase in {\"init\", \"parsed\", \"validated\", \"forwarded\", \"complete\", \"rejected\"}\n    and error_raised in BOOLEAN\n    and forwarded in BOOLEAN\n    and auto_fix in BOOLEAN\n    and cli_retries_omitted in BOOLEAN",
      "message": "Assertion failed: TypeOK \u2014 /\\ phase \\in {\"init\", \"parsed\", \"validated\", \"forwarded\", \"complete\", \"rejected\"}\n    /\\ error_raised \\in BOOLEAN\n   ...",
      "description": "Test assertion for TypeOK from CmdPlanReviewMaxRetries spec"
    },
    "assert_NegativeRejected": {
      "condition": "(and cli_retries_omitted = FALSE\n     and cli_retries_value < 0\n     and phase not in {\"init\", \"parsed\"})\n        implies error_raised = TRUE",
      "message": "Assertion failed: NegativeRejected \u2014 (/\\ cli_retries_omitted = FALSE\n     /\\ cli_retries_value < 0\n     /\\ phase \\notin {\"init\", \"parsed\"})\n        => err...",
      "description": "Test assertion for NegativeRejected from CmdPlanReviewMaxRetries spec"
    },
    "assert_MaxRetriesForwarded": {
      "condition": "(auto_fix and phase = \"complete\")\n        implies (forwarded and orchestrator_retries = parsed_max_retries)",
      "message": "Assertion failed: MaxRetriesForwarded \u2014 (auto_fix /\\ phase = \"complete\")\n        => (forwarded /\\ orchestrator_retries = parsed_max_retries)",
      "description": "Test assertion for MaxRetriesForwarded from CmdPlanReviewMaxRetries spec"
    },
    "assert_ZeroMeansSinglePass": {
      "condition": "(forwarded and parsed_max_retries = 0)\n        implies orchestrator_retries = 0",
      "message": "Assertion failed: ZeroMeansSinglePass \u2014 (forwarded /\\ parsed_max_retries = 0)\n        => orchestrator_retries = 0",
      "description": "Test assertion for ZeroMeansSinglePass from CmdPlanReviewMaxRetries spec"
    },
    "assert_DefaultWhenOmitted": {
      "condition": "(cli_retries_omitted and phase not in {\"init\", \"rejected\"})\n        implies parsed_max_retries = 2",
      "message": "Assertion failed: DefaultWhenOmitted \u2014 (cli_retries_omitted /\\ phase \\notin {\"init\", \"rejected\"})\n        => parsed_max_retries = 2",
      "description": "Test assertion for DefaultWhenOmitted from CmdPlanReviewMaxRetries spec"
    },
    "assert_IgnoredWithoutAutoFix": {
      "condition": "(auto_fix = FALSE and phase = \"complete\")\n        implies forwarded = FALSE",
      "message": "Assertion failed: IgnoredWithoutAutoFix \u2014 (auto_fix = FALSE /\\ phase = \"complete\")\n        => forwarded = FALSE",
      "description": "Test assertion for IgnoredWithoutAutoFix from CmdPlanReviewMaxRetries spec"
    },
    "assert_ValidParsedRetries": {
      "condition": "(error_raised = FALSE and phase not in {\"init\", \"parsed\", \"rejected\"})\n        implies parsed_max_retries >= 0",
      "message": "Assertion failed: ValidParsedRetries \u2014 (error_raised = FALSE /\\ phase \\notin {\"init\", \"parsed\", \"rejected\"})\n        => parsed_max_retries >= 0",
      "description": "Test assertion for ValidParsedRetries from CmdPlanReviewMaxRetries spec"
    }
