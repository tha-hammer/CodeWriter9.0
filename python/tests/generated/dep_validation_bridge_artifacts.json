      "description": "Test assertion for DuplicateRejected from dep_validation spec"
    },
    "assert_KindCompatibilityEnforced": {
      "condition": "(current_state = \"done\" and ValidProposedEdge and is_valid = TRUE and proposed_edge_type = 1 implies\n     ~((node_kind[proposed_from] in {1,2}) and (node_kind[proposed_to] = 3)))",
      "message": "Assertion failed: KindCompatibilityEnforced \u2014 (current_state = \"done\" /\\ ValidProposedEdge /\\ is_valid = TRUE /\\ proposed_edge_type = 1 =>\n     ~((node_kind[propos...",
      "description": "Test assertion for KindCompatibilityEnforced from dep_validation spec"
    },
    "assert_ValidEdgeAccepted": {
      "condition": "(current_state = \"done\" and ValidProposedEdge and\n     proposed_from not in reachable and\n     proposed_to not in adjacency[proposed_from] and\n     ~((proposed_edge_type = 1) and (node_kind[proposed_from] in {1,2}) and (node_kind[proposed_to] = 3))\n     implies is_valid = TRUE)",
      "message": "Assertion failed: ValidEdgeAccepted \u2014 (current_state = \"done\" /\\ ValidProposedEdge /\\\n     proposed_from \\notin reachable /\\\n     proposed_to \\notin adjace...",
      "description": "Test assertion for ValidEdgeAccepted from dep_validation spec"
    }
  }
