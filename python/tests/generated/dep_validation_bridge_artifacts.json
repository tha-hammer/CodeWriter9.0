  "verifiers": {
    "TerminalStates": {
      "function_id": "fn-dep_validation-verify-TerminalStates",
      "acceptance_criteria_id": "ac-dep_validation-TerminalStates",
      "conditions": [
        "{\"done\", \"failed\"}"
      ],
      "message": "TerminalStates violation: {\"done\", \"failed\"}",
      "applies_to": [
        "dep_validation"
      ],
      "description": "Verifier for invariant TerminalStates from dep_validation spec"
    },
    "ValidState": {
      "function_id": "fn-dep_validation-verify-ValidState",
      "acceptance_criteria_id": "ac-dep_validation-ValidState",
      "conditions": [
        "current_state \\in StateSet"
      ],
      "message": "ValidState violation: current_state \\in StateSet",
      "applies_to": [
        "current_state"
      ],
      "description": "Verifier for invariant ValidState from dep_validation spec"
    },
    "BoundedExecution": {
      "function_id": "fn-dep_validation-verify-BoundedExecution",
      "acceptance_criteria_id": "ac-dep_validation-BoundedExecution",
      "conditions": [
        "step_count <= MaxSteps"
      ],
      "message": "BoundedExecution violation: step_count <= MaxSteps",
      "applies_to": [
        "step_count"
      ],
      "description": "Verifier for invariant BoundedExecution from dep_validation spec"
    },
    "ValidProposedEdge": {
      "function_id": "fn-dep_validation-verify-ValidProposedEdge",
      "acceptance_criteria_id": "ac-dep_validation-ValidProposedEdge",
      "conditions": [
        "proposed_from \\in 1..NumNodes",
        "proposed_to \\in 1..NumNodes"
      ],
      "message": "ValidProposedEdge violation: (proposed_from \\in 1..NumNodes) /\\ (proposed_to \\in 1..NumNodes)",
      "applies_to": [
        "proposed_from",
        "proposed_to"
      ],
      "description": "Verifier for invariant ValidProposedEdge from dep_validation spec"
    },
    "AcyclicityPreserved": {
      "function_id": "fn-dep_validation-verify-AcyclicityPreserved",
      "acceptance_criteria_id": "ac-dep_validation-AcyclicityPreserved",
      "conditions": [
        "current_state = \"done\"",
        "ValidProposedEdge",
        "is_valid = TRUE =>\n     proposed_from \\notin reachable"
      ],
      "message": "AcyclicityPreserved violation: (current_state = \"done\" /\\ ValidProposedEdge /\\ is_valid = TRUE =>\n     proposed_from \\notin reachable)",
      "applies_to": [
        "current_state",
        "dirty",
        "is_valid",
        "proposed_from",
        "reachable"
      ],
      "description": "Verifier for invariant AcyclicityPreserved from dep_validation spec"
    },
    "DuplicateRejected": {
      "function_id": "fn-dep_validation-verify-DuplicateRejected",
      "acceptance_criteria_id": "ac-dep_validation-DuplicateRejected",
      "conditions": [
        "current_state = \"done\"",
        "ValidProposedEdge",
        "rejection_reason = \"duplicate\" =>\n     proposed_to \\in adjacency[proposed_from]"
      ],
      "message": "DuplicateRejected violation: (current_state = \"done\" /\\ ValidProposedEdge /\\ rejection_reason = \"duplicate\" =>\n     proposed_to \\in adjacency[prop...",
      "applies_to": [
        "adjacency",
        "current_state",
        "dirty",
        "proposed_from",
        "proposed_to",
        "rejection_reason"
      ],
      "description": "Verifier for invariant DuplicateRejected from dep_validation spec"
    },
    "KindCompatibilityEnforced": {
      "function_id": "fn-dep_validation-verify-KindCompatibilityEnforced",
      "acceptance_criteria_id": "ac-dep_validation-KindCompatibilityEnforced",
      "conditions": [
        "current_state = \"done\"",
        "ValidProposedEdge",
        "is_valid = TRUE",
        "proposed_edge_type = 1 =>\n     ~((node_kind[proposed_from] \\in {1,2}",
        "node_kind[proposed_to] = 3"
      ],
      "message": "KindCompatibilityEnforced violation: (current_state = \"done\" /\\ ValidProposedEdge /\\ is_valid = TRUE /\\ proposed_edge_type = 1 =>\n     ~((node_kind[propos...",
      "applies_to": [
        "current_state",
        "dirty",
        "is_valid",
        "node_kind",
        "proposed_edge_type",
        "proposed_from",
        "proposed_to"
      ],
      "description": "Verifier for invariant KindCompatibilityEnforced from dep_validation spec"
    },
    "ValidEdgeAccepted": {
      "function_id": "fn-dep_validation-verify-ValidEdgeAccepted",
      "acceptance_criteria_id": "ac-dep_validation-ValidEdgeAccepted",
      "conditions": [
        "current_state = \"done\"",
        "ValidProposedEdge",
        "proposed_from \\notin reachable",
        "proposed_to \\notin adjacency[proposed_from]",
        "~((proposed_edge_type = 1",
        "node_kind[proposed_from] \\in {1,2}",
        "node_kind[proposed_to] = 3))\n     => is_valid = TRUE"
      ],
      "message": "ValidEdgeAccepted violation: (current_state = \"done\" /\\ ValidProposedEdge /\\\n     proposed_from \\notin reachable /\\\n     proposed_to \\notin adjace...",
      "applies_to": [
        "adjacency",
        "current_state",
        "dirty",
        "is_valid",
        "node_kind",
        "proposed_edge_type",
        "proposed_from",
        "proposed_to",
        "reachable"
      ],
      "description": "Verifier for invariant ValidEdgeAccepted from dep_validation spec"
    }
  },
