  "assertions": {
    "assert_BothTerminal": {
      "condition": "coverage_verdict in TerminalVerdicts and interaction_verdict in TerminalVerdicts",
      "message": "Assertion failed: BothTerminal \u2014 coverage_verdict \\in TerminalVerdicts /\\ interaction_verdict \\in TerminalVerdicts",
      "description": "Test assertion for BothTerminal from AbstractionGapGating spec"
    },
    "assert_BothRequired": {
      "condition": "ag_scheduled implies\n        coverage_verdict in PermittedVerdicts and\n        interaction_verdict in PermittedVerdicts",
      "message": "Assertion failed: BothRequired \u2014 ag_scheduled =>\n        coverage_verdict \\in PermittedVerdicts /\\\n        interaction_verdict \\in PermittedVerdicts",
      "description": "Test assertion for BothRequired from AbstractionGapGating spec"
    },
    "assert_FailBlocks": {
      "condition": "(coverage_verdict = \"fail\" or interaction_verdict = \"fail\") implies\n        ~ag_scheduled and (evaluated implies ag_blocked)",
      "message": "Assertion failed: FailBlocks \u2014 (coverage_verdict = \"fail\" \\/ interaction_verdict = \"fail\") =>\n        ~ag_scheduled /\\ (evaluated => ag_blocked)",
      "description": "Test assertion for FailBlocks from AbstractionGapGating spec"
    },
    "assert_BlockedPropagates": {
      "condition": "(coverage_verdict = \"blocked\" or interaction_verdict = \"blocked\") implies\n        ~ag_scheduled and (evaluated implies ag_blocked)",
      "message": "Assertion failed: BlockedPropagates \u2014 (coverage_verdict = \"blocked\" \\/ interaction_verdict = \"blocked\") =>\n        ~ag_scheduled /\\ (evaluated => ag_blocked)",
      "description": "Test assertion for BlockedPropagates from AbstractionGapGating spec"
    },
    "assert_WarningPermits": {
      "condition": "(coverage_verdict = \"warning\" and interaction_verdict = \"warning\" and evaluated) implies\n        ag_scheduled and ~ag_blocked",
      "message": "Assertion failed: WarningPermits \u2014 (coverage_verdict = \"warning\" /\\ interaction_verdict = \"warning\" /\\ evaluated) =>\n        ag_scheduled /\\ ~ag_blocked",
      "description": "Test assertion for WarningPermits from AbstractionGapGating spec"
    },
    "assert_MutualExclusion": {
      "condition": "~(ag_scheduled and ag_blocked)",
      "message": "Assertion failed: MutualExclusion \u2014 ~(ag_scheduled /\\ ag_blocked)",
      "description": "Test assertion for MutualExclusion from AbstractionGapGating spec"
    },
    "assert_EvaluatedFinal": {
      "condition": "evaluated implies (ag_scheduled or ag_blocked)",
      "message": "Assertion failed: EvaluatedFinal \u2014 evaluated => (ag_scheduled \\/ ag_blocked)",
      "description": "Test assertion for EvaluatedFinal from AbstractionGapGating spec"
    }
