  "assertions": {
    "assert_BackwardCompatible": {
      "condition": "(terminated and ~cross_cutting) implies\n        (~has_behavioral_report and ~has_behavioral_json)",
      "message": "Assertion failed: BackwardCompatible \u2014 (terminated /\\ ~cross_cutting) =>\n        (~has_behavioral_report /\\ ~has_behavioral_json)",
      "description": "Test assertion for BackwardCompatible from CrossCuttingCLI spec"
    },
    "assert_FlagEnablesBehavioral": {
      "condition": "(terminated and cross_cutting and rules_file_exists) implies\n        has_behavioral_report",
      "message": "Assertion failed: FlagEnablesBehavioral \u2014 (terminated /\\ cross_cutting /\\ rules_file_exists) =>\n        has_behavioral_report",
      "description": "Test assertion for FlagEnablesBehavioral from CrossCuttingCLI spec"
    },
    "assert_JsonIncludesBehavioral": {
      "condition": "(terminated and json_flag and cross_cutting and rules_file_exists) implies\n        has_behavioral_json",
      "message": "Assertion failed: JsonIncludesBehavioral \u2014 (terminated /\\ json_flag /\\ cross_cutting /\\ rules_file_exists) =>\n        has_behavioral_json",
      "description": "Test assertion for JsonIncludesBehavioral from CrossCuttingCLI spec"
    },
    "assert_MissingRulesError": {
      "condition": "(terminated and cross_cutting and ~rules_file_exists) implies\n        (stderr_error and exit_code = 1)",
      "message": "Assertion failed: MissingRulesError \u2014 (terminated /\\ cross_cutting /\\ ~rules_file_exists) =>\n        (stderr_error /\\ exit_code = 1)",
      "description": "Test assertion for MissingRulesError from CrossCuttingCLI spec"
    },
    "assert_BothReportsPresent": {
      "condition": "(terminated and cross_cutting and rules_file_exists) implies\n        (has_seam_report and has_behavioral_report)",
      "message": "Assertion failed: BothReportsPresent \u2014 (terminated /\\ cross_cutting /\\ rules_file_exists) =>\n        (has_seam_report /\\ has_behavioral_report)",
      "description": "Test assertion for BothReportsPresent from CrossCuttingCLI spec"
    },
    "assert_SeamReportAlwaysPresent": {
      "condition": "(terminated and ~stderr_error) implies\n        has_seam_report",
      "message": "Assertion failed: SeamReportAlwaysPresent \u2014 (terminated /\\ ~stderr_error) =>\n        has_seam_report",
      "description": "Test assertion for SeamReportAlwaysPresent from CrossCuttingCLI spec"
    },
    "assert_NoSpuriousBehavioralOnError": {
      "condition": "(terminated and stderr_error) implies\n        (~has_behavioral_report and ~has_behavioral_json)",
      "message": "Assertion failed: NoSpuriousBehavioralOnError \u2014 (terminated /\\ stderr_error) =>\n        (~has_behavioral_report /\\ ~has_behavioral_json)",
      "description": "Test assertion for NoSpuriousBehavioralOnError from CrossCuttingCLI spec"
    },
    "assert_ExitCodeCleanOnSuccess": {
      "condition": "(terminated and ~stderr_error) implies\n        (exit_code = 0)",
      "message": "Assertion failed: ExitCodeCleanOnSuccess \u2014 (terminated /\\ ~stderr_error) =>\n        (exit_code = 0)",
      "description": "Test assertion for ExitCodeCleanOnSuccess from CrossCuttingCLI spec"
    }
  },
