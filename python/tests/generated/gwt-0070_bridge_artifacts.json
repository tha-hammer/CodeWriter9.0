  "verifiers": {
    "BackwardCompatible": {
      "function_id": "fn-CrossCuttingCLI-verify-BackwardCompatible",
      "acceptance_criteria_id": "ac-CrossCuttingCLI-BackwardCompatible",
      "conditions": [
        "terminated",
        "~cross_cutting) =>\n        (~has_behavioral_report",
        "~has_behavioral_json"
      ],
      "message": "BackwardCompatible violation: (terminated /\\ ~cross_cutting) =>\n        (~has_behavioral_report /\\ ~has_behavioral_json)",
      "applies_to": [
        "cross_cutting",
        "has_behavioral_json",
        "has_behavioral_report",
        "terminated"
      ],
      "description": "Verifier for invariant BackwardCompatible from CrossCuttingCLI spec"
    },
    "FlagEnablesBehavioral": {
      "function_id": "fn-CrossCuttingCLI-verify-FlagEnablesBehavioral",
      "acceptance_criteria_id": "ac-CrossCuttingCLI-FlagEnablesBehavioral",
      "conditions": [
        "terminated",
        "cross_cutting",
        "rules_file_exists) =>\n        has_behavioral_report"
      ],
      "message": "FlagEnablesBehavioral violation: (terminated /\\ cross_cutting /\\ rules_file_exists) =>\n        has_behavioral_report",
      "applies_to": [
        "cross_cutting",
        "has_behavioral_report",
        "rules_file_exists",
        "terminated"
      ],
      "description": "Verifier for invariant FlagEnablesBehavioral from CrossCuttingCLI spec"
    },
    "JsonIncludesBehavioral": {
      "function_id": "fn-CrossCuttingCLI-verify-JsonIncludesBehavioral",
      "acceptance_criteria_id": "ac-CrossCuttingCLI-JsonIncludesBehavioral",
      "conditions": [
        "terminated",
        "json_flag",
        "cross_cutting",
        "rules_file_exists) =>\n        has_behavioral_json"
      ],
      "message": "JsonIncludesBehavioral violation: (terminated /\\ json_flag /\\ cross_cutting /\\ rules_file_exists) =>\n        has_behavioral_json",
      "applies_to": [
        "cross_cutting",
        "has_behavioral_json",
        "json_flag",
        "rules_file_exists",
        "terminated"
      ],
      "description": "Verifier for invariant JsonIncludesBehavioral from CrossCuttingCLI spec"
    },
    "MissingRulesError": {
      "function_id": "fn-CrossCuttingCLI-verify-MissingRulesError",
      "acceptance_criteria_id": "ac-CrossCuttingCLI-MissingRulesError",
      "conditions": [
        "terminated",
        "cross_cutting",
        "~rules_file_exists) =>\n        (stderr_error",
        "exit_code = 1"
      ],
      "message": "MissingRulesError violation: (terminated /\\ cross_cutting /\\ ~rules_file_exists) =>\n        (stderr_error /\\ exit_code = 1)",
      "applies_to": [
        "cross_cutting",
        "exit_code",
        "rules_file_exists",
        "stderr_error",
        "terminated"
      ],
      "description": "Verifier for invariant MissingRulesError from CrossCuttingCLI spec"
    },
    "BothReportsPresent": {
      "function_id": "fn-CrossCuttingCLI-verify-BothReportsPresent",
