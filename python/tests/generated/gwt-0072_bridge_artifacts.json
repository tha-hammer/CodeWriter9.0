      "condition": "and gwt_metadata in {NoMetadata, DefaultTmpl, ObsTmpl, UnknownTmpl}\n    and selected_template in {DefaultTmpl, ObsTmpl, UnknownTmpl}\n    and error in BOOLEAN\n    and template_loaded in BOOLEAN\n    and file_exists in BOOLEAN",
