      ],
      "description": "Verifier for invariant DefaultFallback from TemplateSelectedByAnnotation spec"
    },
    "AnnotationRespected": {
      "function_id": "fn-TemplateSelectedByAnnotation-verify-AnnotationRespected",
      "acceptance_criteria_id": "ac-TemplateSelectedByAnnotation-AnnotationRespected",
      "conditions": [
        "\\A t \\in KnownTemplates :\n        (phase = \"prompt_built\"",
        "gwt_metadata = t) =>\n            selected_template = t"
      ],
      "message": "AnnotationRespected violation: \\A t \\in KnownTemplates :\n        (phase = \"prompt_built\" /\\ gwt_metadata = t) =>\n            selected_template = t",
      "applies_to": [
        "gwt_metadata",
        "phase",
        "selected_template"
      ],
      "description": "Verifier for invariant AnnotationRespected from TemplateSelectedByAnnotation spec"
    },
    "NoSilentFallback": {
      "function_id": "fn-TemplateSelectedByAnnotation-verify-NoSilentFallback",
      "acceptance_criteria_id": "ac-TemplateSelectedByAnnotation-NoSilentFallback",
      "conditions": [
        "~(gwt_metadata = UnknownTmpl",
        "template_loaded = TRUE"
      ],
      "message": "NoSilentFallback violation: ~(gwt_metadata = UnknownTmpl /\\ template_loaded = TRUE)",
