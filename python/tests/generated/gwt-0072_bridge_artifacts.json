      "description": "Test assertion for TypeOK from TemplateSelectedByAnnotation spec"
    },
    "assert_DefaultFallback": {
      "condition": "(phase = \"prompt_built\" and gwt_metadata = NoMetadata) implies\n        selected_template = DefaultTmpl",
      "message": "Assertion failed: DefaultFallback \u2014 (phase = \"prompt_built\" /\\ gwt_metadata = NoMetadata) =>\n        selected_template = DefaultTmpl",
      "description": "Test assertion for DefaultFallback from TemplateSelectedByAnnotation spec"
    },
    "assert_AnnotationRespected": {
      "condition": "\\A t in KnownTemplates :\n        (phase = \"prompt_built\" and gwt_metadata = t) implies\n            selected_template = t",
      "message": "Assertion failed: AnnotationRespected \u2014 \\A t \\in KnownTemplates :\n        (phase = \"prompt_built\" /\\ gwt_metadata = t) =>\n            selected_template = t",
      "description": "Test assertion for AnnotationRespected from TemplateSelectedByAnnotation spec"
    },
    "assert_NoSilentFallback": {
      "condition": "~(gwt_metadata = UnknownTmpl and template_loaded = TRUE)",
      "message": "Assertion failed: NoSilentFallback \u2014 ~(gwt_metadata = UnknownTmpl /\\ template_loaded = TRUE)",
      "description": "Test assertion for NoSilentFallback from TemplateSelectedByAnnotation spec"
    },
    "assert_PromptBuiltOnlyIfLoaded": {
      "condition": "phase = \"prompt_built\" implies template_loaded = TRUE",
      "message": "Assertion failed: PromptBuiltOnlyIfLoaded \u2014 phase = \"prompt_built\" => template_loaded = TRUE",
      "description": "Test assertion for PromptBuiltOnlyIfLoaded from TemplateSelectedByAnnotation spec"
    },
    "assert_ErrorMeansNoPrompt": {
      "condition": "error = TRUE implies phase # \"prompt_built\"",
      "message": "Assertion failed: ErrorMeansNoPrompt \u2014 error = TRUE => phase # \"prompt_built\"",
      "description": "Test assertion for ErrorMeansNoPrompt from TemplateSelectedByAnnotation spec"
    },
    "assert_UnknownTemplateImpliesError": {
      "condition": "(gwt_metadata = UnknownTmpl and\n     phase not in {\"idle\", \"metadata_read\", \"template_resolved\"}) implies\n        error = TRUE",
      "message": "Assertion failed: UnknownTemplateImpliesError \u2014 (gwt_metadata = UnknownTmpl /\\\n     phase \\notin {\"idle\", \"metadata_read\", \"template_resolved\"}) =>\n        error = TRUE",
      "description": "Test assertion for UnknownTemplateImpliesError from TemplateSelectedByAnnotation spec"
    },
    "assert_KnownTemplateNeverErrors": {
      "condition": "(gwt_metadata in KnownTemplates and\n     phase not in {\"idle\", \"metadata_read\"}) implies\n        error = FALSE",
      "message": "Assertion failed: KnownTemplateNeverErrors \u2014 (gwt_metadata \\in KnownTemplates /\\\n     phase \\notin {\"idle\", \"metadata_read\"}) =>\n        error = FALSE",
      "description": "Test assertion for KnownTemplateNeverErrors from TemplateSelectedByAnnotation spec"
    }
