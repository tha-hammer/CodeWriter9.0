        "template_loaded"
      ],
      "description": "Verifier for invariant TypeOK from TemplateSelectedByAnnotation spec"
    },
    "DefaultFallback": {
      "function_id": "fn-TemplateSelectedByAnnotation-verify-DefaultFallback",
      "acceptance_criteria_id": "ac-TemplateSelectedByAnnotation-DefaultFallback",
      "conditions": [
        "phase = \"prompt_built\"",
