  "verifiers": {
    "DirectBlockInvariant": {
      "function_id": "fn-PassDependencyBlocking-verify-DirectBlockInvariant",
      "acceptance_criteria_id": "ac-PassDependencyBlocking-DirectBlockInvariant",
      "conditions": [
        "\\A p \\in PASSES :\n    passStatus[p] = \"blocked\" =>\n      \\E dep \\in DEPS[p] : passStatus[dep] \\in BLOCKING"
      ],
      "message": "DirectBlockInvariant violation: \\A p \\in PASSES :\n    passStatus[p] = \"blocked\" =>\n      \\E dep \\in DEPS[p] : passStatus[dep] \\in BLOCKING",
      "applies_to": [
        "passStatus"
      ],
      "description": "Verifier for invariant DirectBlockInvariant from PassDependencyBlocking spec"
    },
    "BlockedNeverRan": {
      "function_id": "fn-PassDependencyBlocking-verify-BlockedNeverRan",
      "acceptance_criteria_id": "ac-PassDependencyBlocking-BlockedNeverRan",
      "conditions": [
        "\\A p \\in PASSES : passStatus[p] = \"blocked\" => p \\notin ran"
      ],
      "message": "BlockedNeverRan violation: \\A p \\in PASSES : passStatus[p] = \"blocked\" => p \\notin ran",
      "applies_to": [
        "passStatus",
        "ran"
      ],
      "description": "Verifier for invariant BlockedNeverRan from PassDependencyBlocking spec"
    },
    "NeverRunBlocked": {
      "function_id": "fn-PassDependencyBlocking-verify-NeverRunBlocked",
      "acceptance_criteria_id": "ac-PassDependencyBlocking-NeverRunBlocked",
      "conditions": [
        "\\A p \\in ran : passStatus[p] # \"blocked\""
      ],
      "message": "NeverRunBlocked violation: \\A p \\in ran : passStatus[p] # \"blocked\"",
      "applies_to": [
        "passStatus",
        "ran"
      ],
      "description": "Verifier for invariant NeverRunBlocked from PassDependencyBlocking spec"
    },
    "ScheduledOnlySatisfied": {
      "function_id": "fn-PassDependencyBlocking-verify-ScheduledOnlySatisfied",
      "acceptance_criteria_id": "ac-PassDependencyBlocking-ScheduledOnlySatisfied",
      "conditions": [
        "\\A p \\in ran :\n    \\A dep \\in DEPS[p] : passStatus[dep] \\in SATISFIED"
      ],
      "message": "ScheduledOnlySatisfied violation: \\A p \\in ran :\n    \\A dep \\in DEPS[p] : passStatus[dep] \\in SATISFIED",
      "applies_to": [
        "passStatus",
        "ran"
      ],
      "description": "Verifier for invariant ScheduledOnlySatisfied from PassDependencyBlocking spec"
    },
    "PartialSuccessInvariant": {
      "function_id": "fn-PassDependencyBlocking-verify-PartialSuccessInvariant",
      "acceptance_criteria_id": "ac-PassDependencyBlocking-PartialSuccessInvariant",
      "conditions": [
        "\\A p \\in PASSES :\n    ( passStatus[p] \\in SATISFIED",
        "\\A dep \\in DEPS[p] : passStatus[dep] \\in SATISFIED ) =>\n    p \\in ran"
      ],
      "message": "PartialSuccessInvariant violation: \\A p \\in PASSES :\n    ( passStatus[p] \\in SATISFIED /\\\n      \\A dep \\in DEPS[p] : passStatus[dep] \\in SATISFIED ) =>\n...",
      "applies_to": [
        "passStatus",
        "ran"
      ],
      "description": "Verifier for invariant PartialSuccessInvariant from PassDependencyBlocking spec"
    },
    "BlockedDistinctFromFail": {
      "function_id": "fn-PassDependencyBlocking-verify-BlockedDistinctFromFail",
      "acceptance_criteria_id": "ac-PassDependencyBlocking-BlockedDistinctFromFail",
      "conditions": [
        "\\A p \\in PASSES :\n    ~( passStatus[p] = \"blocked\"",
        "passStatus[p] = \"FAIL\" "
      ],
      "message": "BlockedDistinctFromFail violation: \\A p \\in PASSES :\n    ~( passStatus[p] = \"blocked\" /\\ passStatus[p] = \"FAIL\" )",
      "applies_to": [
        "passStatus"
      ],
      "description": "Verifier for invariant BlockedDistinctFromFail from PassDependencyBlocking spec"
    },
    "FinalAllResolved": {
      "function_id": "fn-PassDependencyBlocking-verify-FinalAllResolved",
      "acceptance_criteria_id": "ac-PassDependencyBlocking-FinalAllResolved",
      "conditions": [
        "idx > Len(TOPO) =>\n    \\A p \\in PASSES : passStatus[p] \\in TERMINAL"
      ],
      "message": "FinalAllResolved violation: idx > Len(TOPO) =>\n    \\A p \\in PASSES : passStatus[p] \\in TERMINAL",
      "applies_to": [
        "idx",
        "passStatus"
      ],
      "description": "Verifier for invariant FinalAllResolved from PassDependencyBlocking spec"
    },
    "TransitiveBlockWitness": {
      "function_id": "fn-PassDependencyBlocking-verify-TransitiveBlockWitness",
      "acceptance_criteria_id": "ac-PassDependencyBlocking-TransitiveBlockWitness",
      "conditions": [
        "\\A p \\in PASSES :\n    passStatus[p] = \"blocked\" =>\n      \\E dep \\in DEPS[p] : passStatus[dep] \\in BLOCKING\n\nVARIABLE cp"
      ],
      "message": "TransitiveBlockWitness violation: \\A p \\in PASSES :\n    passStatus[p] = \"blocked\" =>\n      \\E dep \\in DEPS[p] : passStatus[dep] \\in BLOCKING\n\nVARIABLE cp",
      "applies_to": [
        "passStatus"
      ],
      "description": "Verifier for invariant TransitiveBlockWitness from PassDependencyBlocking spec"
    }
  },
  "assertions": {
    "assert_DirectBlockInvariant": {
      "condition": "\\A p in PASSES :\n    passStatus[p] = \"blocked\" implies\n      \\E dep in DEPS[p] : passStatus[dep] in BLOCKING",
      "message": "Assertion failed: DirectBlockInvariant \u2014 \\A p \\in PASSES :\n    passStatus[p] = \"blocked\" =>\n      \\E dep \\in DEPS[p] : passStatus[dep] \\in BLOCKING",
      "description": "Test assertion for DirectBlockInvariant from PassDependencyBlocking spec"
    },
    "assert_BlockedNeverRan": {
      "condition": "\\A p in PASSES : passStatus[p] = \"blocked\" implies p not in ran",
      "message": "Assertion failed: BlockedNeverRan \u2014 \\A p \\in PASSES : passStatus[p] = \"blocked\" => p \\notin ran",
      "description": "Test assertion for BlockedNeverRan from PassDependencyBlocking spec"
    },
    "assert_NeverRunBlocked": {
      "condition": "\\A p in ran : passStatus[p] # \"blocked\"",
      "message": "Assertion failed: NeverRunBlocked \u2014 \\A p \\in ran : passStatus[p] # \"blocked\"",
      "description": "Test assertion for NeverRunBlocked from PassDependencyBlocking spec"
    },
    "assert_ScheduledOnlySatisfied": {
      "condition": "\\A p in ran :\n    \\A dep in DEPS[p] : passStatus[dep] in SATISFIED",
      "message": "Assertion failed: ScheduledOnlySatisfied \u2014 \\A p \\in ran :\n    \\A dep \\in DEPS[p] : passStatus[dep] \\in SATISFIED",
      "description": "Test assertion for ScheduledOnlySatisfied from PassDependencyBlocking spec"
    },
    "assert_PartialSuccessInvariant": {
      "condition": "\\A p in PASSES :\n    ( passStatus[p] in SATISFIED and\n      \\A dep in DEPS[p] : passStatus[dep] in SATISFIED ) implies\n    p in ran",
      "message": "Assertion failed: PartialSuccessInvariant \u2014 \\A p \\in PASSES :\n    ( passStatus[p] \\in SATISFIED /\\\n      \\A dep \\in DEPS[p] : passStatus[dep] \\in SATISFIED ) =>\n...",
      "description": "Test assertion for PartialSuccessInvariant from PassDependencyBlocking spec"
    },
    "assert_BlockedDistinctFromFail": {
      "condition": "\\A p in PASSES :\n    ~( passStatus[p] = \"blocked\" and passStatus[p] = \"FAIL\" )",
      "message": "Assertion failed: BlockedDistinctFromFail \u2014 \\A p \\in PASSES :\n    ~( passStatus[p] = \"blocked\" /\\ passStatus[p] = \"FAIL\" )",
      "description": "Test assertion for BlockedDistinctFromFail from PassDependencyBlocking spec"
    },
    "assert_FinalAllResolved": {
      "condition": "idx > Len(TOPO) implies\n    \\A p in PASSES : passStatus[p] in TERMINAL",
      "message": "Assertion failed: FinalAllResolved \u2014 idx > Len(TOPO) =>\n    \\A p \\in PASSES : passStatus[p] \\in TERMINAL",
      "description": "Test assertion for FinalAllResolved from PassDependencyBlocking spec"
    },
    "assert_TransitiveBlockWitness": {
      "condition": "\\A p in PASSES :\n    passStatus[p] = \"blocked\" implies\n      \\E dep in DEPS[p] : passStatus[dep] in BLOCKING\n\nVARIABLE cp",
      "message": "Assertion failed: TransitiveBlockWitness \u2014 \\A p \\in PASSES :\n    passStatus[p] = \"blocked\" =>\n      \\E dep \\in DEPS[p] : passStatus[dep] \\in BLOCKING\n\nVARIABLE cp",
      "description": "Test assertion for TransitiveBlockWitness from PassDependencyBlocking spec"
    }
