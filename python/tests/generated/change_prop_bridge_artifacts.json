  "verifiers": {
    "ValidState": {
      "function_id": "fn-change_propagation-verify-ValidState",
      "acceptance_criteria_id": "ac-change_propagation-ValidState",
      "conditions": [
        "current_state \\in StateSet"
      ],
      "message": "ValidState violation: current_state \\in StateSet",
      "applies_to": [
        "current_state"
      ],
      "description": "Verifier for invariant ValidState from change_propagation spec"
    },
    "BoundedExecution": {
      "function_id": "fn-change_propagation-verify-BoundedExecution",
      "acceptance_criteria_id": "ac-change_propagation-BoundedExecution",
      "conditions": [
        "step_count <= MaxSteps\n\nReachable(start, adj) ==\n    LET RECURSIVE Reach(_)\n        Reach(visited) ==\n            LET next == UNION {adj[n] : n \\in visited} \\ visited\n            IN IF next = {} THEN visited ELSE Reach(visited \\union next)\n    IN Reach({start}"
      ],
      "message": "BoundedExecution violation: step_count <= MaxSteps\n\nReachable(start, adj) ==\n    LET RECURSIVE Reach(_)\n        Reach(visited) ==\n            LET...",
      "applies_to": [
        "step_count"
      ],
      "description": "Verifier for invariant BoundedExecution from change_propagation spec"
    },
    "NoFalsePositives": {
      "function_id": "fn-change_propagation-verify-NoFalsePositives",
      "acceptance_criteria_id": "ac-change_propagation-NoFalsePositives",
      "conditions": [
        "current_state = \"done\" =>\n        \\A a \\in affected_tests : \\E n \\in candidates : test_artifacts[n] = a"
      ],
      "message": "NoFalsePositives violation: (current_state = \"done\" =>\n        \\A a \\in affected_tests : \\E n \\in candidates : test_artifacts[n] = a)",
      "applies_to": [
        "affected_tests",
        "candidates",
        "current_state",
        "dirty",
        "test_artifacts"
      ],
      "description": "Verifier for invariant NoFalsePositives from change_propagation spec"
    },
    "NoFalseNegatives": {
      "function_id": "fn-change_propagation-verify-NoFalseNegatives",
      "acceptance_criteria_id": "ac-change_propagation-NoFalseNegatives",
      "conditions": [
        "current_state = \"done\" =>\n        \\A n \\in candidates : test_artifacts[n] # 0 => test_artifacts[n] \\in affected_tests"
      ],
      "message": "NoFalseNegatives violation: (current_state = \"done\" =>\n        \\A n \\in candidates : test_artifacts[n] # 0 => test_artifacts[n] \\in affected_tests)",
      "applies_to": [
        "affected_tests",
        "candidates",
        "current_state",
        "dirty",
        "test_artifacts"
      ],
      "description": "Verifier for invariant NoFalseNegatives from change_propagation spec"
    },
    "SelfTestIncluded": {
      "function_id": "fn-change_propagation-verify-SelfTestIncluded",
      "acceptance_criteria_id": "ac-change_propagation-SelfTestIncluded",
      "conditions": [
        "current_state = \"done\" =>\n        (test_artifacts[target] # 0 => test_artifacts[target] \\in affected_tests"
      ],
      "message": "SelfTestIncluded violation: (current_state = \"done\" =>\n        (test_artifacts[target] # 0 => test_artifacts[target] \\in affected_tests))",
      "applies_to": [
        "affected_tests",
        "current_state",
        "dirty",
        "target",
        "test_artifacts"
      ],
      "description": "Verifier for invariant SelfTestIncluded from change_propagation spec"
    }
  },
