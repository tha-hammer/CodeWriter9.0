    "impact_analysisState": {
      "function_id": "fn-impact_analysis-state",
      "acceptance_criteria_id": "ac-impact_analysis-state",
      "fields": {
        "pc": {
          "type": "shared/data_types/Record",
          "required": true,
          "unique": false,
          "default": "[self \\in ProcSet |-> \"Loop\"]",
          "validation": [
            "NotNull"
          ]
        },
        "current_state": {
          "type": "shared/data_types/String",
          "required": true,
          "unique": false,
          "default": "idle",
          "validation": [
            "IsString"
          ]
        },
        "adjacency": {
          "type": "shared/data_types/Record",
          "required": true,
          "unique": false,
          "default": "[n \\in 1..NumNodes |-> {}]",
          "validation": [
            "NotNull"
          ]
        },
        "edge_count": {
          "type": "shared/data_types/Integer",
          "required": true,
          "unique": false,
          "default": "0",
          "validation": [
            "IsInteger"
          ]
        },
        "target": {
          "type": "shared/data_types/Integer",
          "required": true,
          "unique": false,
          "default": "0",
          "validation": [
            "IsInteger"
          ]
        },
        "reverse_set": {
          "type": "shared/data_types/Set",
          "required": true,
          "unique": false,
          "default": "empty_set",
          "validation": [
            "IsSet"
          ]
        },
        "visited": {
          "type": "shared/data_types/Set",
          "required": true,
          "unique": false,
          "default": "empty_set",
          "validation": [
            "IsSet"
          ]
        },
        "worklist": {
          "type": "shared/data_types/Set",
          "required": true,
          "unique": false,
          "default": "empty_set",
          "validation": [
            "IsSet"
          ]
        },
        "direct_dependents": {
          "type": "shared/data_types/Set",
          "required": true,
          "unique": false,
          "default": "empty_set",
          "validation": [
            "IsSet"
          ]
        },
        "step_count": {
          "type": "shared/data_types/Integer",
          "required": true,
          "unique": false,
          "default": "0",
          "validation": [
            "IsInteger"
          ]
        },
        "op": {
          "type": "shared/data_types/String",
          "required": true,
          "unique": false,
          "default": "idle",
          "validation": [
            "IsString"
          ]
        },
        "result": {
          "type": "shared/data_types/String",
          "required": true,
          "unique": false,
          "default": "none",
          "validation": [
            "IsString"
          ]
        },
        "dirty": {
          "type": "shared/data_types/Boolean",
          "required": true,
          "unique": false,
          "default": "false",
          "validation": [
            "IsBoolean"
          ]
        }
      },
      "relations": {},
      "description": "State model derived from impact_analysis TLA+ spec"
    }
  },
