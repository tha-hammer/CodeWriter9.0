  "verifiers": {
    "TerminalStates": {
      "function_id": "fn-impact_analysis-verify-TerminalStates",
      "acceptance_criteria_id": "ac-impact_analysis-TerminalStates",
      "conditions": [
        "{\"done\", \"failed\"}"
      ],
      "message": "TerminalStates violation: {\"done\", \"failed\"}",
      "applies_to": [
        "impact_analysis"
      ],
      "description": "Verifier for invariant TerminalStates from impact_analysis spec"
    },
    "ValidState": {
      "function_id": "fn-impact_analysis-verify-ValidState",
      "acceptance_criteria_id": "ac-impact_analysis-ValidState",
      "conditions": [
        "current_state \\in StateSet"
      ],
      "message": "ValidState violation: current_state \\in StateSet",
      "applies_to": [
        "current_state"
      ],
      "description": "Verifier for invariant ValidState from impact_analysis spec"
    },
    "BoundedExecution": {
      "function_id": "fn-impact_analysis-verify-BoundedExecution",
      "acceptance_criteria_id": "ac-impact_analysis-BoundedExecution",
      "conditions": [
        "step_count <= MaxSteps"
      ],
      "message": "BoundedExecution violation: step_count <= MaxSteps",
      "applies_to": [
        "step_count"
      ],
      "description": "Verifier for invariant BoundedExecution from impact_analysis spec"
    },
    "ReverseClosureComplete": {
      "function_id": "fn-impact_analysis-verify-ReverseClosureComplete",
      "acceptance_criteria_id": "ac-impact_analysis-ReverseClosureComplete",
      "conditions": [
        "current_state = \"done\"",
        "target # 0) =>\n        \\A n \\in reverse_set :\n            \\E path_len \\in 1..NumNodes :\n                \\E path \\in [1..path_len -> 1..NumNodes] :",
        "path[1] = n",
        "path[path_len] = target",
        "\\A i \\in 1..(path_len-1) : path[i+1] \\in adjacency[path[i]]"
      ],
      "message": "ReverseClosureComplete violation: (current_state = \"done\" /\\ target # 0) =>\n        \\A n \\in reverse_set :\n            \\E path_len \\in 1..NumNodes :\n  ...",
      "applies_to": [
        "adjacency",
        "current_state",
        "dirty",
        "reverse_set",
        "target"
      ],
      "description": "Verifier for invariant ReverseClosureComplete from impact_analysis spec"
    },
    "LeafHasNoImpact": {
      "function_id": "fn-impact_analysis-verify-LeafHasNoImpact",
      "acceptance_criteria_id": "ac-impact_analysis-LeafHasNoImpact",
      "conditions": [
        "current_state = \"done\"",
        "target # 0) =>\n        ((\\A p \\in 1..NumNodes : target \\notin adjacency[p]) => reverse_set = {}"
      ],
      "message": "LeafHasNoImpact violation: (current_state = \"done\" /\\ target # 0) =>\n        ((\\A p \\in 1..NumNodes : target \\notin adjacency[p]) => reverse_set...",
      "applies_to": [
        "adjacency",
        "current_state",
        "dirty",
        "reverse_set",
        "target"
      ],
      "description": "Verifier for invariant LeafHasNoImpact from impact_analysis spec"
    },
    "DirectDependentsIncluded": {
      "function_id": "fn-impact_analysis-verify-DirectDependentsIncluded",
      "acceptance_criteria_id": "ac-impact_analysis-DirectDependentsIncluded",
      "conditions": [
        "current_state = \"done\"",
        "target # 0) =>\n        direct_dependents \\subseteq reverse_set"
      ],
      "message": "DirectDependentsIncluded violation: (current_state = \"done\" /\\ target # 0) =>\n        direct_dependents \\subseteq reverse_set",
      "applies_to": [
        "current_state",
        "direct_dependents",
        "dirty",
        "reverse_set",
        "target"
      ],
      "description": "Verifier for invariant DirectDependentsIncluded from impact_analysis spec"
    },
    "MonotonicGrowth": {
      "function_id": "fn-impact_analysis-verify-MonotonicGrowth",
      "acceptance_criteria_id": "ac-impact_analysis-MonotonicGrowth",
      "conditions": [
        "dirty = TRUE \\/ TRUE"
      ],
      "message": "MonotonicGrowth violation: TRUE",
      "applies_to": [
        "dirty"
      ],
      "description": "Verifier for invariant MonotonicGrowth from impact_analysis spec"
    }
  },
  "assertions": {
    "assert_TerminalStates": {
      "condition": "{\"done\", \"failed\"}",
      "message": "Assertion failed: TerminalStates \u2014 {\"done\", \"failed\"}",
      "description": "Test assertion for TerminalStates from impact_analysis spec"
    },
    "assert_ValidState": {
      "condition": "current_state in StateSet",
      "message": "Assertion failed: ValidState \u2014 current_state \\in StateSet",
      "description": "Test assertion for ValidState from impact_analysis spec"
    },
    "assert_BoundedExecution": {
      "condition": "step_count <= MaxSteps",
      "message": "Assertion failed: BoundedExecution \u2014 step_count <= MaxSteps",
      "description": "Test assertion for BoundedExecution from impact_analysis spec"
    },
    "assert_ReverseClosureComplete": {
      "condition": "(current_state = \"done\" and target # 0) implies\n        \\A n in reverse_set :\n            \\E path_len in 1..NumNodes :\n                \\E path in [1..path_len -> 1..NumNodes] :\n                    and path[1] = n\n                    and path[path_len] = target\n                    and \\A i in 1..(path_len-1) : path[i+1] in adjacency[path[i]]",
      "message": "Assertion failed: ReverseClosureComplete \u2014 (current_state = \"done\" /\\ target # 0) =>\n        \\A n \\in reverse_set :\n            \\E path_len \\in 1..NumNodes :\n  ...",
      "description": "Test assertion for ReverseClosureComplete from impact_analysis spec"
    },
    "assert_LeafHasNoImpact": {
      "condition": "(current_state = \"done\" and target # 0) implies\n        ((\\A p in 1..NumNodes : target not in adjacency[p]) implies reverse_set = {})",
      "message": "Assertion failed: LeafHasNoImpact \u2014 (current_state = \"done\" /\\ target # 0) =>\n        ((\\A p \\in 1..NumNodes : target \\notin adjacency[p]) => reverse_set...",
      "description": "Test assertion for LeafHasNoImpact from impact_analysis spec"
    },
    "assert_DirectDependentsIncluded": {
      "condition": "(current_state = \"done\" and target # 0) implies\n        direct_dependents \\subseteq reverse_set",
      "message": "Assertion failed: DirectDependentsIncluded \u2014 (current_state = \"done\" /\\ target # 0) =>\n        direct_dependents \\subseteq reverse_set",
      "description": "Test assertion for DirectDependentsIncluded from impact_analysis spec"
    },
    "assert_MonotonicGrowth": {
      "condition": "TRUE",
      "message": "Assertion failed: MonotonicGrowth \u2014 TRUE",
      "description": "Test assertion for MonotonicGrowth from impact_analysis spec"
    }
  }
}