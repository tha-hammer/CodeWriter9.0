  "verifiers": {
    "MutualExclusionOnComposedSpecs": {
      "function_id": "fn-loop_compose_composed-verify-MutualExclusionOnComposedSpecs",
      "acceptance_criteria_id": "ac-loop_compose_composed-MutualExclusionOnComposedSpecs",
      "conditions": [
        "composed_specs \\subseteq (composed_specs \\union {\"new_spec\"}"
      ],
      "message": "MutualExclusionOnComposedSpecs violation: composed_specs \\subseteq (composed_specs \\union {\"new_spec\"})",
      "applies_to": [
        "composed_specs"
      ],
      "description": "Verifier for invariant MutualExclusionOnComposedSpecs from loop_compose_composed spec"
    },
    "LoopValidState": {
      "function_id": "fn-loop_compose_composed-verify-LoopValidState",
      "acceptance_criteria_id": "ac-loop_compose_composed-LoopValidState",
      "conditions": [
        "loop_state \\in LoopStateSet"
      ],
      "message": "LoopValidState violation: loop_state \\in LoopStateSet",
      "applies_to": [
        "loop_state"
      ],
      "description": "Verifier for invariant LoopValidState from loop_compose_composed spec"
    },
    "LoopMutualExclusionOnCompose": {
      "function_id": "fn-loop_compose_composed-verify-LoopMutualExclusionOnCompose",
      "acceptance_criteria_id": "ac-loop_compose_composed-LoopMutualExclusionOnCompose",
      "conditions": [
        "loop_(loop_state = \"composing\" => compose_busy = TRUE"
      ],
      "message": "LoopMutualExclusionOnCompose violation: loop_(loop_state = \"composing\" => compose_busy = TRUE)",
      "applies_to": [
        "compose_busy",
        "loop_dirty",
        "loop_state"
      ],
      "description": "Verifier for invariant LoopMutualExclusionOnCompose from loop_compose_composed spec"
    },
    "LoopTwoFailureLimit": {
      "function_id": "fn-loop_compose_composed-verify-LoopTwoFailureLimit",
      "acceptance_criteria_id": "ac-loop_compose_composed-LoopTwoFailureLimit",
      "conditions": [
        "loop_(consecutive_failures > MaxRetries => loop_state \\in {\"failed\", \"routing\"}"
      ],
      "message": "LoopTwoFailureLimit violation: loop_(consecutive_failures > MaxRetries => loop_state \\in {\"failed\", \"routing\"})",
      "applies_to": [
        "consecutive_failures",
        "loop_dirty",
        "loop_state"
      ],
      "description": "Verifier for invariant LoopTwoFailureLimit from loop_compose_composed spec"
    },
    "LoopDeterministicRouting": {
      "function_id": "fn-loop_compose_composed-verify-LoopDeterministicRouting",
      "acceptance_criteria_id": "ac-loop_compose_composed-LoopDeterministicRouting",
      "conditions": [
        "loop_(loop_state = \"done\" => tlc_passed = TRUE"
      ],
      "message": "LoopDeterministicRouting violation: loop_(loop_state = \"done\" => tlc_passed = TRUE)",
      "applies_to": [
        "loop_dirty",
        "loop_state",
        "tlc_passed"
      ],
      "description": "Verifier for invariant LoopDeterministicRouting from loop_compose_composed spec"
    },
    "LoopBoundedExecution": {
      "function_id": "fn-loop_compose_composed-verify-LoopBoundedExecution",
      "acceptance_criteria_id": "ac-loop_compose_composed-LoopBoundedExecution",
      "conditions": [
        "loop_step <= MaxSteps"
      ],
      "message": "LoopBoundedExecution violation: loop_step <= MaxSteps",
      "applies_to": [
        "loop_step"
      ],
      "description": "Verifier for invariant LoopBoundedExecution from loop_compose_composed spec"
    },
    "EngineValidState": {
      "function_id": "fn-loop_compose_composed-verify-EngineValidState",
      "acceptance_criteria_id": "ac-loop_compose_composed-EngineValidState",
      "conditions": [
        "engine_state \\in EngineStateSet"
      ],
      "message": "EngineValidState violation: engine_state \\in EngineStateSet",
      "applies_to": [
        "engine_state"
      ],
      "description": "Verifier for invariant EngineValidState from loop_compose_composed spec"
    },
    "EngineMonotonicGrowth": {
      "function_id": "fn-loop_compose_composed-verify-EngineMonotonicGrowth",
      "acceptance_criteria_id": "ac-loop_compose_composed-EngineMonotonicGrowth",
      "conditions": [
        "verified_set \\subseteq registered"
      ],
      "message": "EngineMonotonicGrowth violation: verified_set \\subseteq registered",
      "applies_to": [
        "registered",
        "verified_set"
      ],
      "description": "Verifier for invariant EngineMonotonicGrowth from loop_compose_composed spec"
    },
    "EngineBoundedExecution": {
      "function_id": "fn-loop_compose_composed-verify-EngineBoundedExecution",
      "acceptance_criteria_id": "ac-loop_compose_composed-EngineBoundedExecution",
      "conditions": [
        "engine_step <= MaxSteps"
      ],
      "message": "EngineBoundedExecution violation: engine_step <= MaxSteps",
      "applies_to": [
        "engine_step"
      ],
      "description": "Verifier for invariant EngineBoundedExecution from loop_compose_composed spec"
    },
    "EngineDerivedConsistency": {
      "function_id": "fn-loop_compose_composed-verify-EngineDerivedConsistency",
      "acceptance_criteria_id": "ac-loop_compose_composed-EngineDerivedConsistency",
      "conditions": [
        "engine_",
        "composed_from \\subseteq registered",
        "verified_set \\subseteq registered)\n\nVARIABLE sid"
      ],
      "message": "EngineDerivedConsistency violation: engine_(/\\ composed_from \\subseteq registered\n     /\\ verified_set \\subseteq registered)\n\nVARIABLE sid",
      "applies_to": [
        "composed_from",
        "engine_dirty",
        "registered",
        "verified_set"
      ],
      "description": "Verifier for invariant EngineDerivedConsistency from loop_compose_composed spec"
    }
  },
