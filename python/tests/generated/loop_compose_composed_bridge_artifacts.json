      "description": "Test assertion for LoopDeterministicRouting from loop_compose_composed spec"
    },
    "assert_LoopBoundedExecution": {
      "condition": "loop_step <= MaxSteps",
      "message": "Assertion failed: LoopBoundedExecution \u2014 loop_step <= MaxSteps",
      "description": "Test assertion for LoopBoundedExecution from loop_compose_composed spec"
    },
    "assert_EngineValidState": {
      "condition": "engine_state in EngineStateSet",
      "message": "Assertion failed: EngineValidState \u2014 engine_state \\in EngineStateSet",
      "description": "Test assertion for EngineValidState from loop_compose_composed spec"
    },
    "assert_EngineMonotonicGrowth": {
      "condition": "verified_set \\subseteq registered",
      "message": "Assertion failed: EngineMonotonicGrowth \u2014 verified_set \\subseteq registered",
      "description": "Test assertion for EngineMonotonicGrowth from loop_compose_composed spec"
    },
    "assert_EngineBoundedExecution": {
      "condition": "engine_step <= MaxSteps",
      "message": "Assertion failed: EngineBoundedExecution \u2014 engine_step <= MaxSteps",
      "description": "Test assertion for EngineBoundedExecution from loop_compose_composed spec"
    },
    "assert_EngineDerivedConsistency": {
      "condition": "engine_(and composed_from \\subseteq registered\n     and verified_set \\subseteq registered)\n\nVARIABLE sid",
      "message": "Assertion failed: EngineDerivedConsistency \u2014 engine_(/\\ composed_from \\subseteq registered\n     /\\ verified_set \\subseteq registered)\n\nVARIABLE sid",
      "description": "Test assertion for EngineDerivedConsistency from loop_compose_composed spec"
    }
