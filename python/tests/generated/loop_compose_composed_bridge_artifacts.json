      "message": "Assertion failed: LoopMutualExclusionOnCompose \u2014 loop_(loop_state = \"composing\" => compose_busy = TRUE)",
      "description": "Test assertion for LoopMutualExclusionOnCompose from loop_compose_composed spec"
    },
    "assert_LoopTwoFailureLimit": {
