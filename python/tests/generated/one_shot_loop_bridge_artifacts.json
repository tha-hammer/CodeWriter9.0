  "verifiers": {
    "ValidState": {
      "function_id": "fn-one_shot_loop-verify-ValidState",
      "acceptance_criteria_id": "ac-one_shot_loop-ValidState",
      "conditions": [
        "current_state \\in StateSet"
      ],
      "message": "ValidState violation: current_state \\in StateSet",
      "applies_to": [
        "current_state"
      ],
      "description": "Verifier for invariant ValidState from one_shot_loop spec"
    },
    "MutualExclusionOnCompose": {
      "function_id": "fn-one_shot_loop-verify-MutualExclusionOnCompose",
      "acceptance_criteria_id": "ac-one_shot_loop-MutualExclusionOnCompose",
      "conditions": [
        "current_state = \"composing\" => compose_busy = TRUE"
      ],
      "message": "MutualExclusionOnCompose violation: (current_state = \"composing\" => compose_busy = TRUE)",
      "applies_to": [
        "compose_busy",
        "current_state",
        "dirty"
      ],
      "description": "Verifier for invariant MutualExclusionOnCompose from one_shot_loop spec"
    },
    "TwoFailureLimit": {
      "function_id": "fn-one_shot_loop-verify-TwoFailureLimit",
      "acceptance_criteria_id": "ac-one_shot_loop-TwoFailureLimit",
      "conditions": [
        "consecutive_failures > MaxRetries => current_state \\in {\"failed\", \"routing\"}"
      ],
      "message": "TwoFailureLimit violation: (consecutive_failures > MaxRetries => current_state \\in {\"failed\", \"routing\"})",
      "applies_to": [
        "consecutive_failures",
        "current_state",
        "dirty"
      ],
      "description": "Verifier for invariant TwoFailureLimit from one_shot_loop spec"
    },
    "DeterministicRouting": {
      "function_id": "fn-one_shot_loop-verify-DeterministicRouting",
      "acceptance_criteria_id": "ac-one_shot_loop-DeterministicRouting",
      "conditions": [
        "current_state = \"done\" => tlc_passed = TRUE"
      ],
      "message": "DeterministicRouting violation: (current_state = \"done\" => tlc_passed = TRUE)",
      "applies_to": [
        "current_state",
        "dirty",
        "tlc_passed"
      ],
      "description": "Verifier for invariant DeterministicRouting from one_shot_loop spec"
    },
    "BoundedExecution": {
      "function_id": "fn-one_shot_loop-verify-BoundedExecution",
      "acceptance_criteria_id": "ac-one_shot_loop-BoundedExecution",
      "conditions": [
        "step_count <= MaxSteps"
      ],
      "message": "BoundedExecution violation: step_count <= MaxSteps",
      "applies_to": [
        "step_count"
      ],
      "description": "Verifier for invariant BoundedExecution from one_shot_loop spec"
    },
    "DerivedConsistency": {
      "function_id": "fn-one_shot_loop-verify-DerivedConsistency",
      "acceptance_criteria_id": "ac-one_shot_loop-DerivedConsistency",
      "conditions": [
        "current_state = \"done\" => consecutive_failures = 0"
      ],
      "message": "DerivedConsistency violation: (current_state = \"done\" => consecutive_failures = 0)",
      "applies_to": [
        "consecutive_failures",
        "current_state",
        "dirty"
      ],
      "description": "Verifier for invariant DerivedConsistency from one_shot_loop spec"
    }
  },
  "assertions": {
    "assert_ValidState": {
      "condition": "current_state in StateSet",
      "message": "Assertion failed: ValidState \u2014 current_state \\in StateSet",
      "description": "Test assertion for ValidState from one_shot_loop spec"
    },
    "assert_MutualExclusionOnCompose": {
      "condition": "(current_state = \"composing\" implies compose_busy = TRUE)",
      "message": "Assertion failed: MutualExclusionOnCompose \u2014 (current_state = \"composing\" => compose_busy = TRUE)",
      "description": "Test assertion for MutualExclusionOnCompose from one_shot_loop spec"
    },
    "assert_TwoFailureLimit": {
      "condition": "(consecutive_failures > MaxRetries implies current_state in {\"failed\", \"routing\"})",
      "message": "Assertion failed: TwoFailureLimit \u2014 (consecutive_failures > MaxRetries => current_state \\in {\"failed\", \"routing\"})",
      "description": "Test assertion for TwoFailureLimit from one_shot_loop spec"
    },
    "assert_DeterministicRouting": {
      "condition": "(current_state = \"done\" implies tlc_passed = TRUE)",
      "message": "Assertion failed: DeterministicRouting \u2014 (current_state = \"done\" => tlc_passed = TRUE)",
      "description": "Test assertion for DeterministicRouting from one_shot_loop spec"
    },
    "assert_BoundedExecution": {
      "condition": "step_count <= MaxSteps",
      "message": "Assertion failed: BoundedExecution \u2014 step_count <= MaxSteps",
      "description": "Test assertion for BoundedExecution from one_shot_loop spec"
    },
    "assert_DerivedConsistency": {
      "condition": "(current_state = \"done\" implies consecutive_failures = 0)",
      "message": "Assertion failed: DerivedConsistency \u2014 (current_state = \"done\" => consecutive_failures = 0)",
      "description": "Test assertion for DerivedConsistency from one_shot_loop spec"
    }
