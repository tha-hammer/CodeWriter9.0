    },
    "assert_NoDanglingEdges": {
      "condition": "current_state # \"done\" or\n    (\\A edge in subgraph_edges :\n        edge[1] in subgraph_nodes and edge[2] in subgraph_nodes)",
      "message": "Assertion failed: NoDanglingEdges \u2014 current_state # \"done\" \\/\n    (\\A edge \\in subgraph_edges :\n        edge[1] \\in subgraph_nodes /\\ edge[2] \\in subgrap...",
      "description": "Test assertion for NoDanglingEdges from subgraph_extraction spec"
    },
    "assert_IsolatedNodeCorrect": {
      "condition": "current_state # \"done\" or\n    ((adjacency[target] = {} and (\\A n in 1..NumNodes : target not in adjacency[n])) implies\n     (subgraph_nodes = {target} and subgraph_edges = {}))",
      "message": "Assertion failed: IsolatedNodeCorrect \u2014 current_state # \"done\" \\/\n    ((adjacency[target] = {} /\\ (\\A n \\in 1..NumNodes : target \\notin adjacency[n])) =>\n   ...",
      "description": "Test assertion for IsolatedNodeCorrect from subgraph_extraction spec"
    }
  }
