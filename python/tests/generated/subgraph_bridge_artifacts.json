  "verifiers": {
    "ValidState": {
      "function_id": "fn-subgraph_extraction-verify-ValidState",
      "acceptance_criteria_id": "ac-subgraph_extraction-ValidState",
      "conditions": [
        "current_state \\in StateSet"
      ],
      "message": "ValidState violation: current_state \\in StateSet",
      "applies_to": [
        "current_state"
      ],
      "description": "Verifier for invariant ValidState from subgraph_extraction spec"
    },
    "BoundedExecution": {
      "function_id": "fn-subgraph_extraction-verify-BoundedExecution",
      "acceptance_criteria_id": "ac-subgraph_extraction-BoundedExecution",
      "conditions": [
        "step_count <= MaxSteps"
      ],
      "message": "BoundedExecution violation: step_count <= MaxSteps",
      "applies_to": [
        "step_count"
      ],
      "description": "Verifier for invariant BoundedExecution from subgraph_extraction spec"
    },
    "SubgraphCompleteness": {
      "function_id": "fn-subgraph_extraction-verify-SubgraphCompleteness",
      "acceptance_criteria_id": "ac-subgraph_extraction-SubgraphCompleteness",
      "conditions": [
        "current_state # \"done\" \\/\n    (target \\in subgraph_nodes",
        "forward_set \\subseteq subgraph_nodes",
        "reverse_set \\subseteq subgraph_nodes"
      ],
      "message": "SubgraphCompleteness violation: current_state # \"done\" \\/\n    (target \\in subgraph_nodes /\\\n     forward_set \\subseteq subgraph_nodes /\\\n     reverse...",
      "applies_to": [
        "current_state",
        "dirty",
        "forward_set",
        "reverse_set",
        "subgraph_nodes",
        "target"
      ],
      "description": "Verifier for invariant SubgraphCompleteness from subgraph_extraction spec"
    },
    "NoHoles": {
      "function_id": "fn-subgraph_extraction-verify-NoHoles",
      "acceptance_criteria_id": "ac-subgraph_extraction-NoHoles",
      "conditions": [
        "current_state # \"done\" \\/\n    (subgraph_nodes = forward_set \\union reverse_set \\union {target}"
      ],
      "message": "NoHoles violation: current_state # \"done\" \\/\n    (subgraph_nodes = forward_set \\union reverse_set \\union {target})",
      "applies_to": [
        "current_state",
        "dirty",
        "forward_set",
        "reverse_set",
        "subgraph_nodes",
        "target"
      ],
      "description": "Verifier for invariant NoHoles from subgraph_extraction spec"
    },
    "NoDanglingEdges": {
      "function_id": "fn-subgraph_extraction-verify-NoDanglingEdges",
      "acceptance_criteria_id": "ac-subgraph_extraction-NoDanglingEdges",
      "conditions": [
        "current_state # \"done\" \\/\n    (\\A edge \\in subgraph_edges :\n        edge[1] \\in subgraph_nodes",
        "edge[2] \\in subgraph_nodes"
      ],
      "message": "NoDanglingEdges violation: current_state # \"done\" \\/\n    (\\A edge \\in subgraph_edges :\n        edge[1] \\in subgraph_nodes /\\ edge[2] \\in subgrap...",
      "applies_to": [
        "current_state",
        "dirty",
        "subgraph_edges",
        "subgraph_nodes"
      ],
      "description": "Verifier for invariant NoDanglingEdges from subgraph_extraction spec"
    },
    "IsolatedNodeCorrect": {
      "function_id": "fn-subgraph_extraction-verify-IsolatedNodeCorrect",
      "acceptance_criteria_id": "ac-subgraph_extraction-IsolatedNodeCorrect",
      "conditions": [
        "current_state # \"done\" \\/\n    ((adjacency[target] = {}",
        "\\A n \\in 1..NumNodes : target \\notin adjacency[n])) =>\n     (subgraph_nodes = {target}",
        "subgraph_edges = {}"
      ],
      "message": "IsolatedNodeCorrect violation: current_state # \"done\" \\/\n    ((adjacency[target] = {} /\\ (\\A n \\in 1..NumNodes : target \\notin adjacency[n])) =>\n   ...",
      "applies_to": [
        "adjacency",
        "current_state",
        "dirty",
        "subgraph_edges",
        "subgraph_nodes",
        "target"
      ],
      "description": "Verifier for invariant IsolatedNodeCorrect from subgraph_extraction spec"
    }
  },
