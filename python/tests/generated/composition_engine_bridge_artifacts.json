{
  "module_name": "composition_engine",
  "data_structures": {
    "composition_engineState": {
      "function_id": "fn-composition_engine-state",
      "acceptance_criteria_id": "ac-composition_engine-state",
      "fields": {
        "pc": {
          "type": "shared/data_types/Record",
          "required": true,
          "unique": false,
          "default": "[self \\in ProcSet |-> \"Loop\"]",
          "validation": [
            "NotNull"
          ]
        },
        "current_state": {
          "type": "shared/data_types/String",
          "required": true,
          "unique": false,
          "default": "empty",
          "validation": [
            "IsString"
          ]
        },
        "registered": {
          "type": "shared/data_types/Set",
          "required": true,
          "unique": false,
          "default": "empty_set",
          "validation": [
            "IsSet"
          ]
        },
        "composed_from": {
          "type": "shared/data_types/Set",
          "required": true,
          "unique": false,
          "default": "empty_set",
          "validation": [
            "IsSet"
          ]
        },
        "verified_set": {
          "type": "shared/data_types/Set",
          "required": true,
          "unique": false,
          "default": "empty_set",
          "validation": [
            "IsSet"
          ]
        },
        "step_count": {
          "type": "shared/data_types/Integer",
          "required": true,
          "unique": false,
          "default": "0",
          "validation": [
            "IsInteger"
          ]
        },
        "op": {
          "type": "shared/data_types/String",
          "required": true,
          "unique": false,
          "default": "idle",
          "validation": [
            "IsString"
          ]
        },
        "result": {
          "type": "shared/data_types/String",
          "required": true,
          "unique": false,
          "default": "none",
          "validation": [
            "IsString"
          ]
        },
        "dirty": {
          "type": "shared/data_types/Boolean",
          "required": true,
          "unique": false,
          "default": "false",
          "validation": [
            "IsBoolean"
          ]
        }
      },
      "relations": {},
      "description": "State model derived from composition_engine TLA+ spec"
    }
  },
  "operations": {
    "Loop": {
      "function_id": "fn-composition_engine-Loop",
